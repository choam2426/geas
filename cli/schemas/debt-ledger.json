{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "debt_id",
          "status",
          "title",
          "summary",
          "impact",
          "source_refs",
          "accepted_in_ref",
          "revisit_when",
          "resolved_by_refs"
        ],
        "properties": {
          "debt_id": {
            "type": "string",
            "pattern": "^DEBT-[0-9]{3}$"
          },
          "status": {
            "type": "string",
            "enum": ["open", "resolved", "dropped"]
          },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "impact": { "type": "string" },
          "source_refs": { "type": "array", "items": { "type": "string" } },
          "accepted_in_ref": { "type": "string" },
          "revisit_when": { "type": "array", "items": { "type": "string" } },
          "resolved_by_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
