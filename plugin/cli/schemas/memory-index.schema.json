{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GEAS Memory Index",
  "type": "object",
  "properties": {
    "meta": {
      "$ref": "_defs.schema.json#/$defs/commonMeta"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "memory_id": {
            "type": "string"
          },
          "memory_type": {
            "$ref": "_defs.schema.json#/$defs/memoryType"
          },
          "state": {
            "$ref": "_defs.schema.json#/$defs/memoryState"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "review_after": {
            "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
          }
        },
        "required": [
          "memory_id",
          "memory_type",
          "state",
          "confidence",
          "tags",
          "review_after"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "meta",
    "entries"
  ],
  "additionalProperties": false
}