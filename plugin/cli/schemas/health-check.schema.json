{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HealthCheck",
  "description": "Health signal calculation results. 8 signals from protocol doc 10, each with a value, threshold, and whether it triggered a mandatory response. Calculated at phase transitions, session start, and evolving phase entry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "signals",
    "any_triggered",
    "created_at"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "health_check"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "producer_type": {
      "type": "string",
      "const": "orchestration-authority"
    },
    "signals": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value", "threshold", "triggered"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "memory_bloat",
              "review_gap",
              "gate_quality_issue",
              "contradiction_accumulation",
              "repeated_failure_class",
              "debt_stagnation",
              "scope_control_weakness",
              "worker_low_confidence"
            ]
          },
          "value": {
            "type": "number",
            "description": "Current measured value for this signal"
          },
          "threshold": {
            "type": "number",
            "description": "Threshold from protocol doc 10"
          },
          "triggered": {
            "type": "boolean",
            "description": "true if value exceeds threshold"
          },
          "detail": {
            "type": "string",
            "description": "Human-readable explanation of the measurement"
          },
          "mandatory_response": {
            "type": "string",
            "description": "The response that was or will be executed (only present when triggered = true)"
          }
        }
      }
    },
    "any_triggered": {
      "type": "boolean",
      "description": "true if any signal exceeded its threshold"
    },
    "trigger_context": {
      "type": "string",
      "enum": [
        "phase_transition",
        "session_start",
        "evolving_entry",
        "manual"
      ],
      "description": "What event triggered this health check"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
