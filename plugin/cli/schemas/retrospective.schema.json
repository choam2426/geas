{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Retrospective",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "task_id",
    "what_went_well",
    "what_broke",
    "what_was_surprising",
    "rule_candidates",
    "memory_candidates",
    "debt_candidates",
    "next_time_guidance",
    "created_at"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "retrospective"
    },
    "artifact_id": {
      "type": "string"
    },
    "producer_type": {
      "type": "string",
      "const": "orchestration_authority"
    },
    "task_id": {
      "type": "string"
    },
    "what_went_well": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "what_broke": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "what_was_surprising": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rule_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "memory_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "debt_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_time_guidance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    }
  }
}