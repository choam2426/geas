      })
    );
  });
}
function registerList(debt) {
  debt.command("list").description(
    "Read-only query over `.geas/debts.json`. Filters on --status and/or --mission (matches introduced_by.mission_id OR resolved_by.mission_id)."
  ).option("--status <status>", "Filter by status (open|resolved|dropped)").option("--mission <id>", "Filter by mission (matches origin or resolution)").action((opts) => {
    if (opts.status !== void 0 && !STATUS_ENUM.has(opts.status)) {
      emit(
        err(
          "invalid_argument",
          `--status must be one of ${[...STATUS_ENUM].join(", ")}`
        )
      );
    }
    if (opts.mission !== void 0 && !isValidMissionId(opts.mission)) {
      emit(err("invalid_argument", `invalid mission id '${opts.mission}'`));
    }
    const root = needProjectRoot9();
    const ledger = loadLedger(root);
    let entries = ledger.entries.slice();
    if (opts.status) {
      entries = entries.filter(
        (e) => e.status === opts.status
      );
    }
    if (opts.mission) {
      const m = opts.mission;
      entries = entries.filter((e) => {
        const ib = e.introduced_by;
        const rb = e.resolved_by;
        if (ib && ib.mission_id === m) return true;
        if (rb && rb.mission_id === m) return true;
        return false;
      });
    }
    const counts = { open: 0, resolved: 0, dropped: 0 };
    for (const e of entries) {
      const s = e.status ?? "";
      if (counts[s] !== void 0) counts[s]++;
    }
    emit(
      ok({
        path: slashPath8(debtsPath(root)),
        total: entries.length,
        counts,
        entries
      })
    );
  });
}
