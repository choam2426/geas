      emit(
        err(
          "invalid_argument",
          "debt update-status expects a JSON object payload"
        )
      );
    }
    const allowedKeys = /* @__PURE__ */ new Set(["status", "resolved_by", "resolution_rationale"]);
    for (const k of Object.keys(payload)) {
