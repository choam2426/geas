            { field: k }
          )
        );
      }
    }
    if (typeof payload.status !== "string" || !STATUS_ENUM.has(payload.status)) {
      emit(
        err(
          "invalid_argument",
          `status must be one of ${[...STATUS_ENUM].join(", ")}`
        )
      );
    }
    if (payload.status === "open") {
      if (payload.resolved_by !== void 0 && payload.resolved_by !== null) {
        emit(
          err(
            "invalid_argument",
            "resolved_by must be null when status is open"
