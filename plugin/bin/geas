// src/lib/paths.ts
var path = __toESM(require("path"));
var fs = __toESM(require("fs"));
var import_child_process = require("child_process");
function normalizePath(p) {
  return path.resolve(p).replace(/\\/g, "/");
}
function resolveGeasDir(cwd) {
  const base = cwd ?? process.cwd();
  try {
    const gitCommonDir = (0, import_child_process.execSync)("git rev-parse --git-common-dir", {
      cwd: base,
      encoding: "utf-8",
      stdio: ["pipe", "pipe", "pipe"]
    }).trim();
    const mainRepoRoot = path.resolve(base, gitCommonDir, "..");
    const gitBased = path.resolve(mainRepoRoot, ".geas");
    if (fs.existsSync(gitBased)) {
      return normalizePath(gitBased);
    }
  } catch {
  }
  const direct = path.resolve(base, ".geas");
  if (fs.existsSync(direct)) {
    return normalizePath(direct);
  }
  const err = new Error(
    `.geas/ directory not found at ${normalizePath(direct)} (also checked git main repo root)`
  );
  err.code = "FILE_ERROR";
  throw err;
}
function resolveMissionDir(geasDir2, missionId) {
  const missionDir = path.resolve(geasDir2, "missions", missionId);
  if (!fs.existsSync(missionDir)) {
    const err = new Error(
      `Mission directory not found: ${normalizePath(missionDir)}`
    );
    err.code = "FILE_ERROR";
    throw err;
  }
  return normalizePath(missionDir);
}
var SAFE_ID_RE = /^[A-Za-z0-9_-]+$/;
function validateIdentifier(id, label) {
  if (!SAFE_ID_RE.test(id)) {
    const err = new Error(
      `Invalid ${label}: "${id}". Only alphanumeric, underscore, and hyphen are allowed.`
    );
    err.code = "FILE_ERROR";
    throw err;
  }
}
function assertContainedIn(resolvedPath, baseDir) {
  const normalizedBase = path.resolve(baseDir) + path.sep;
  const normalizedPath = path.resolve(resolvedPath);
  if (!normalizedPath.startsWith(normalizedBase) && normalizedPath !== path.resolve(baseDir)) {
    const err = new Error(
      `Path "${resolvedPath}" escapes base directory "${baseDir}"`
    );
    err.code = "FILE_ERROR";
    throw err;
  }
}

// src/lib/fs-atomic.ts
var fs3 = __toESM(require("fs"));
var path3 = __toESM(require("path"));

// src/lib/post-write-checks.ts
var fs2 = __toESM(require("fs"));
var path2 = __toESM(require("path"));
function norm(p) {
  return p.replace(/\\/g, "/");
}
function readJsonSafe(filePath) {
  try {
    return JSON.parse(fs2.readFileSync(filePath, "utf-8"));
  } catch {
    return null;
  }
}
function fileExists(p) {
  try {
    fs2.accessSync(p);
    return true;
  } catch {
    return false;
  }
}
function fnmatch(str, pattern) {
  let re = "^";
  for (let i = 0; i < pattern.length; i++) {
    const c = pattern[i];
    if (c === "*") re += ".*";
    else if (c === "?") re += ".";
    else re += c.replace(/[.+^${}()|[\]\\]/g, "\\$&");
  }
  re += "$";
  return new RegExp(re).test(str);
}
function matchScope(rel, scopePaths) {
  if (!scopePaths || scopePaths.length === 0) return true;
  return scopePaths.some(
    (p) => fnmatch(rel, p) || rel.startsWith(p.replace(/\/$/, "") + "/")
  );
}
function relPath(filePath, cwd) {
  return path2.relative(cwd, filePath).replace(/\\/g, "/");
}
function geasDir(cwd) {
  return path2.join(cwd, ".geas");
}
function isoTimestamp() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
function enrichTimestamp(filePath, data) {
  const normFp = norm(filePath);
  if (!normFp.includes("/.geas/") || !normFp.endsWith(".json")) return data;
  if (typeof data !== "object" || data === null) return data;
  const d = data;
  if (fs2.existsSync(filePath)) {
    d.updated_at = isoTimestamp();
  }
  const ts = d.created_at || "";
  if (!ts || /:00:00Z$/.test(ts) || /:00:00\.000Z$/.test(ts)) {
    d.created_at = isoTimestamp();
  }
  return data;
}
function checkScopeAndFrozenSpec(filePath, _data, cwd) {
  const warnings = [];
  const normFp = norm(filePath);
  const rel = relPath(filePath, cwd);
  const geas = geasDir(cwd);
  if (!rel.startsWith(".geas/") && !rel.startsWith(".geas\\")) {
    const run2 = readJsonSafe(path2.join(geas, "state", "run.json"));
    if (run2 && run2.current_task_id) {
      const mid = run2.mission_id || "";
      const mdir = mid ? path2.join(geas, "missions", mid) : geas;
      const task = readJsonSafe(
        path2.join(mdir, "tasks", run2.current_task_id, "contract.json")
      );
      if (task) {
        const scope = task.scope;
        const scopePaths = scope?.surfaces || [];
        if (scopePaths.length > 0 && !matchScope(rel, scopePaths)) {
          warnings.push(
            `Write to ${rel} outside scope.surfaces in ${run2.current_task_id}`
          );
        }
      }
    }
  }
  if (normFp.includes("/.geas/missions/") && normFp.endsWith("/spec.json")) {
    warnings.push(
      "Mission spec was modified. Mission specs should be frozen after intake. Use a vote round for scope changes."
    );
  }
  return warnings;
}
function checkTaskPassedEvidence(filePath, data, cwd) {
  const normFp = norm(filePath);
  if (!normFp.includes("/.geas/missions/") || !normFp.endsWith("/contract.json")) return [];
  const d = typeof data === "object" && data !== null ? data : null;
  if (!d || d.status !== "passed") return [];
  const tid = d.task_id || d.id || "";
  if (!tid) return [];
  const geas = geasDir(cwd);
  const run2 = readJsonSafe(path2.join(geas, "state", "run.json"));
  const mid = run2?.mission_id;
  if (!mid) return [];
  const mdir = path2.join(geas, "missions", mid);
  const edir = path2.join(mdir, "tasks", tid, "evidence");
  const tdir = path2.join(mdir, "tasks", tid);
  const warnings = [];
  const routing = d.routing || {};
  const reviewerTypes = routing.required_reviewer_types || [];
  for (const rt of reviewerTypes) {
    const kebab = rt.replace(/_/g, "-");
    const found = fileExists(path2.join(edir, kebab + "-review.json")) || fileExists(path2.join(edir, kebab + ".json")) || fileExists(path2.join(edir, rt + "-review.json")) || fileExists(path2.join(edir, rt + ".json"));
    if (!found) {
      warnings.push(`${tid} marked as passed but evidence from ${rt} is missing`);
    }
  }
  const recordPath = path2.join(tdir, "record.json");
  const record = readJsonSafe(recordPath);
  const sections = record || {};
  if (!sections.verdict) {
    warnings.push(`${tid} marked as passed but record.json verdict section is missing`);
  }
  const riskLevel = d.risk_level || "normal";
  if (["high", "critical"].includes(riskLevel)) {
    if (!sections.challenge_review) {
      warnings.push(`${tid} is ${riskLevel} risk but record.json challenge_review section is missing`);
    }
  }
  if (!sections.retrospective) {
    warnings.push(`${tid} marked as passed but record.json retrospective section is missing`);
  }
  try {
    const files = fs2.readdirSync(edir).filter((f) => f.endsWith(".json"));
    for (const f of files) {
      const review = readJsonSafe(path2.join(edir, f));
      if (review && review.reviewer_type && (!review.rubric_scores || Object.keys(review.rubric_scores).length === 0)) {
        warnings.push(`${tid} ${f} is missing rubric_scores`);
      }
    }
  } catch {
  }
  return warnings;
}
function checkDebtThreshold(filePath, data, _cwd) {
  const normFp = norm(filePath);
  if (!normFp.includes(".geas/missions/")) return [];
  const d = typeof data === "object" && data !== null ? data : null;
  if (!d || !Array.isArray(d.items)) return [];
  const items = d.items;
  const highOpen = items.filter(
    (i) => i.severity === "high" && i.status === "open"
  );
  if (highOpen.length >= 3) {
    return [
      `Debt register has ${highOpen.length} open HIGH severity items. Consider addressing before proceeding.`
    ];
  }
  return [];
}
function checkLockConflicts(filePath, data, _cwd) {
  const normFp = norm(filePath);
  if (!normFp.endsWith(".geas/state/locks.json")) return [];
  const d = typeof data === "object" && data !== null ? data : null;
  if (!d || !Array.isArray(d.locks)) return [];
  const locks = d.locks;
  const held = locks.filter((l) => l.status === "held");
  const byType = {};
  for (const l of held) {
    const lt = l.lock_type || "unknown";
    if (!byType[lt]) byType[lt] = [];
    byType[lt].push(l);
  }
  const conflicts = [];
  for (const [type, group] of Object.entries(byType)) {
    for (let i = 0; i < group.length; i++) {
      for (let j = i + 1; j < group.length; j++) {
        if (group[i].task_id === group[j].task_id) continue;
        const targetsI = group[i].targets || [];
        const targetsJ = group[j].targets || [];
        const overlap = targetsI.filter((t) => targetsJ.includes(t));
        if (overlap.length > 0) {
          conflicts.push(
            `${type}: ${group[i].task_id} vs ${group[j].task_id} on [${overlap.join(", ")}]`
          );
        }
      }
    }
  }
  if (conflicts.length > 0) {
    return [
      "Lock conflicts detected:",
      ...conflicts.map((c) => "  " + c)
    ];
  }
  return [];
}
function writeCheckpointPending(filePath, cwd) {
  const normFp = norm(filePath);
  if (!normFp.endsWith(".geas/state/run.json")) return;
  const runFile = path2.join(cwd, ".geas", "state", "run.json");
  const pendingFile = path2.join(cwd, ".geas", "state", "_checkpoint_pending");
  if (fileExists(runFile)) {
    try {
      fs2.copyFileSync(runFile, pendingFile);
    } catch {
    }
  }
}
function cleanupCheckpointPending(filePath, cwd) {
  const normFp = norm(filePath);
  if (!normFp.endsWith(".geas/state/run.json")) return;
  const pendingFile = path2.join(cwd, ".geas", "state", "_checkpoint_pending");
  if (fileExists(pendingFile)) {
    try {
      fs2.unlinkSync(pendingFile);
    } catch {
    }
  }
}
function checkPacketStaleness(filePath, data, cwd) {
  const normFp = norm(filePath);
  if (!normFp.endsWith(".geas/state/run.json")) return [];
  const d = typeof data === "object" && data !== null ? data : null;
  if (!d || !d.current_task_id || !d.recovery_class) return [];
  const taskId = d.current_task_id;
  const recoveryClass = d.recovery_class;
  const packetsDir = path2.join(geasDir(cwd), "packets", taskId);
  try {
    const files = fs2.readdirSync(packetsDir).filter((f) => f.endsWith(".md"));
    if (files.length > 0) {
      return [
        `Recovery detected (${recoveryClass}). Context packets in packets/${taskId}/ may be stale. Consider regenerating.`
      ];
    }
  } catch {
  }
  return [];
}
function runPostWriteChecks(filePath, data, cwd) {
  const warnings = [];
  warnings.push(...checkScopeAndFrozenSpec(filePath, data, cwd));
  warnings.push(...checkTaskPassedEvidence(filePath, data, cwd));
  warnings.push(...checkDebtThreshold(filePath, data, cwd));
  warnings.push(...checkLockConflicts(filePath, data, cwd));
  cleanupCheckpointPending(filePath, cwd);
  warnings.push(...checkPacketStaleness(filePath, data, cwd));
  return warnings;
}

