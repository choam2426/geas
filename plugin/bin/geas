function ensureDir(dirPath) {
  fs.mkdirSync(dirPath, { recursive: true });
}
function readJsonFile(filePath) {
  let content;
  try {
    content = fs.readFileSync(filePath, "utf-8");
  } catch (err2) {
    const e = err2;
    if (e.code === "ENOENT") return null;
    throw err2;
  }
  try {
    return JSON.parse(content);
  } catch (err2) {
    if (err2 instanceof SyntaxError) {
      throw new Error(
        `Failed to parse JSON at ${filePath.replace(/\\/g, "/")}: ${err2.message}`
      );
    }
    throw err2;
  }
}
function makeTempPath(targetPath, tmpRoot) {
  const baseName = path.basename(targetPath);
  const rand = crypto.randomBytes(6).toString("hex");
  const name = `${baseName}.${process.pid}.${rand}`;
  if (tmpRoot) return path.join(tmpRoot, name);
  return path.join(path.dirname(targetPath), `.${name}.tmp`);
}
function atomicWrite(targetPath, content, tmpRoot = null) {
  ensureDir(path.dirname(targetPath));
  if (tmpRoot) ensureDir(tmpRoot);
  const tmpPath = makeTempPath(targetPath, tmpRoot);
  let fd = null;
  try {
    fd = fs.openSync(tmpPath, fs.constants.O_WRONLY | fs.constants.O_CREAT | fs.constants.O_EXCL, 384);
    fs.writeSync(fd, content, 0, "utf-8");
    try {
      fs.fsyncSync(fd);
    } catch {
    }
    fs.closeSync(fd);
    fd = null;
    try {
      fs.renameSync(tmpPath, targetPath);
    } catch (err2) {
      const e = err2;
      if (e.code === "EXDEV" || e.code === "EPERM") {
        fs.copyFileSync(tmpPath, targetPath);
        fs.unlinkSync(tmpPath);
      } else {
        throw err2;
      }
    }
  } catch (err2) {
    if (fd !== null) {
      try {
        fs.closeSync(fd);
      } catch {
      }
    }
    try {
      fs.unlinkSync(tmpPath);
    } catch {
    }
    throw err2;
  }
}
function atomicWriteJson(targetPath, data, tmpRoot = null) {
  const content = JSON.stringify(data, null, 2) + "\n";
  atomicWrite(targetPath, content, tmpRoot);
}
function appendJsonl(filePath, entry) {
  ensureDir(path.dirname(filePath));
