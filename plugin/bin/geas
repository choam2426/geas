// src/lib/errors.ts
var EXIT_CATEGORY_CODE = {
  validation: 2,
  guard: 3,
  missing_artifact: 4,
  io: 5,
  internal: 1
};
function exitCodeForCategory(category) {
  if (Object.prototype.hasOwnProperty.call(EXIT_CATEGORY_CODE, category)) {
    return EXIT_CATEGORY_CODE[category];
  }
  return EXIT_CATEGORY_CODE.internal;
}
function makeError(code, message, options = {}) {
  const error = {
    code,
    message,
    exit_category: options.exit_category ?? "internal"
  };
  if (options.hint !== void 0) {
    error.hint = options.hint;
  }
  return error;
}

// src/lib/output.ts
var activeState = {
  mode: "default",
  verbose: false,
  debug: false
};
function setOutputMode(state) {
  activeState = {
    mode: state.mode ?? activeState.mode,
    verbose: state.verbose ?? activeState.verbose,
    debug: state.debug ?? activeState.debug
  };
}
function getOutputMode() {
  return { ...activeState };
}
var formatterRegistry = /* @__PURE__ */ new Map();
function lookupFormatter(commandName) {
  return formatterRegistry.get(commandName);
}
function jsonStringify(value, debug) {
  return debug ? JSON.stringify(value, null, 2) : JSON.stringify(value);
}
function writeOkEnvelope(commandName, data) {
  const state = getOutputMode();
  const useJson = state.mode === "json" || !lookupFormatter(commandName);
  if (useJson) {
    process.stdout.write(jsonStringify({ ok: true, data }, state.debug) + "\n");
  } else {
    const fmt = lookupFormatter(commandName);
    const text = fmt ? fmt(data) : jsonStringify({ ok: true, data }, state.debug);
    process.stdout.write(text.endsWith("\n") ? text : text + "\n");
  }
}
function emitOk(commandName, data) {
  writeOkEnvelope(commandName, data);
  process.exit(0);
}
function writeErrEnvelope(error) {
  const state = getOutputMode();
  if (state.mode === "json" || state.mode === "default") {
    const payload = {
      ok: false,
      error: {
        code: error.code,
        message: error.message
      }
    };
    if (error.hint !== void 0) {
      payload.error.hint = error.hint;
    }
    process.stdout.write(jsonStringify(payload, state.debug) + "\n");
  } else {
    process.stderr.write(`error: ${error.message}
`);
    if (error.hint !== void 0) {
      process.stderr.write(`hint: ${error.hint}
`);
    }
  }
}
function emitErr(error) {
  writeErrEnvelope(error);
  process.exit(exitCodeForCategory(error.exit_category));
}
function writeLegacyErrEnvelope(envelope) {
  const state = getOutputMode();
  process.stdout.write(jsonStringify(envelope, state.debug) + "\n");
}

