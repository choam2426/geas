  record.command("add").description("Add or overwrite a section in record.json (JSON via stdin and/or --set)").option("--mission <mission-id>", "Mission identifier (auto-resolved from run.json)").requiredOption("--task <task-id>", "Task identifier").requiredOption("--section <name>", `Section name (${VALID_SECTIONS.join(", ")})`).option("--set <key=value...>", "Set individual fields", collectSet, []).option("--dry-run", "Validate input without writing files").action((opts) => {
    try {
      const cwd = getCwd(cmd);
      const geasDir2 = resolveGeasDir(cwd);
      const missionId = resolveMissionId(geasDir2, opts.mission);
      validateIdentifier(missionId, "mission ID");
      validateIdentifier(opts.task, "task ID");
      const missionDir = resolveMissionDir(geasDir2, missionId);
      if (!isValidSection(opts.section)) {
        fileError("", "record add", `Invalid section: '${opts.section}'. Valid: ${VALID_SECTIONS.join(", ")}`);
        return;
      }
      const taskDir = path8.resolve(missionDir, "tasks", opts.task);
      if (!fs9.existsSync(taskDir)) {
        fileError(normalizePath(taskDir), "record add", `Task directory not found: ${opts.task}`);
        return;
      }
      let sectionData;
      try {
        sectionData = readInputData();
      } catch (readErr) {
        const rnErr = readErr;
        if (rnErr.code === "NO_STDIN") {
          sectionData = void 0;
        } else if (rnErr.code === "INVALID_JSON") {
          if (opts.dryRun) {
            dryRunParseError(rnErr.message);
            return;
          }
          fileError("", "parse", rnErr.message);
          return;
        } else {
          throw readErr;
        }
      }
      if (opts.set.length > 0) {
        const overrides = parseSetFlags(opts.set);
        if (sectionData) {
          deepMergeSetOverrides(sectionData, overrides);
        } else {
          sectionData = overrides;
        }
      }
      if (!sectionData) {
        noStdinError(
          "task record add",
          "No data provided. Pipe JSON to stdin, or use --set <key=value>."
        );
        return;
      }
      const recordPath = path8.resolve(taskDir, "record.json");
      let record2 = readJsonFile(recordPath);
      if (!record2) {
        record2 = { version: "1.0", task_id: opts.task };
      }
      const existing = record2[opts.section];
      if (existing && typeof existing === "object" && !Array.isArray(existing)) {
        record2[opts.section] = { ...existing, ...sectionData };
      } else {
        record2[opts.section] = sectionData;
      }
      if (opts.dryRun) {
        dryRunGuard(true, record2, "record");
        return;
      }
      const result = validate("record", record2);
      if (!result.valid) {
        validationError("record", result.errors);
        return;
      }
      writeJsonFile(recordPath, record2, { cwd });
      success({
        written: normalizePath(recordPath),
        task_id: opts.task,
        mission_id: missionId,
        section: opts.section,
        action: "added"
      });
    } catch (err) {
      const nodeErr = err;
      if (nodeErr.code === "FILE_ERROR") {
        fileError("", "record add", nodeErr.message);
      } else {
        throw err;
      }
    }
  });
  record.command("get").description("Read record.json (full or specific section)").option("--mission <mission-id>", "Mission identifier (auto-resolved from run.json)").requiredOption("--task <task-id>", "Task identifier").option("--section <name>", "Section name (omit for full record)").action((opts) => {
