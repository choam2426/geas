var fs5 = __toESM(require("fs"));
var NO_STDIN = "NO_STDIN";
var NO_STDIN_EXAMPLES = [
  `heredoc:      geas <cmd> <<'JSON'
                {"key": "value"}
                JSON`,
  `pipe:         echo '{"key":"value"}' | geas <cmd>`,
  "redirection:  geas <cmd> < payload.json"
];
function noStdinError2(reason) {
  const lines = [
    `No JSON on stdin: ${reason}`,
    "Write commands require JSON piped via stdin. Examples:",
    ...NO_STDIN_EXAMPLES.map((e) => `  ${e}`)
  ];
  const err = new Error(lines.join("\n"));
  err.code = NO_STDIN;
  return err;
}
function computeJsonLineHint(raw, err) {
  const msg = err.message;
  const posMatch = /position\s+(\d+)/.exec(msg);
  if (!posMatch) {
    return msg;
  }
  const pos = parseInt(posMatch[1], 10);
  if (!Number.isFinite(pos) || pos < 0) {
    return msg;
  }
  let line = 1;
  let col = 1;
  const scanEnd = Math.min(pos, raw.length);
  for (let i = 0; i < scanEnd; i++) {
    if (raw.charCodeAt(i) === 10) {
      line++;
      col = 1;
    } else {
      col++;
    }
  }
  return `${msg} (line ${line}, column ${col})`;
}
function readInputData() {
  if (process.stdin.isTTY === true) {
    throw noStdinError2("stdin is an interactive terminal (TTY)");
  }
  let raw;
  try {
    raw = fs5.readFileSync(0, "utf-8");
  } catch (err) {
    const nodeErr = err;
    const code = nodeErr.code;
    const errno = nodeErr.errno;
    if (code === "EAGAIN" || code === "EOF" || code === "ENOENT" || errno === -4095) {
      throw noStdinError2("stdin is empty or unavailable");
    }
    throw noStdinError2(`failed to read stdin (${code || "unknown"})`);
  }
  if (raw.charCodeAt(0) === 65279) {
    raw = raw.slice(1);
  }
  raw = raw.trim();
  if (raw.length === 0) {
    throw noStdinError2("stdin was empty (0 bytes after trim)");
  }
  try {
    return JSON.parse(raw);
  } catch (e) {
    if (e instanceof SyntaxError) {
      const hint = computeJsonLineHint(raw, e);
      const err2 = new Error(`Invalid JSON on stdin: ${hint}`);
      err2.code = "INVALID_JSON";
      throw err2;
    }
    const msg = e instanceof Error ? e.message : String(e);
    const err = new Error(`Invalid JSON on stdin: ${msg}`);
    err.code = "INVALID_JSON";
    throw err;
  }
}
var DANGEROUS_KEYS = /* @__PURE__ */ new Set(["__proto__", "constructor", "prototype"]);
var MAX_SET_DEPTH = 10;
function parseSegments(key) {
  const parts = key.split(".");
  if (parts.length > MAX_SET_DEPTH) {
    throw new Error(
      `--set key "${key}" exceeds maximum depth of ${MAX_SET_DEPTH} segments`
    );
  }
  const segments = [];
  for (const part of parts) {
    if (part === "") {
      throw new Error(
        `--set key "${key}" contains an empty segment (leading, trailing, or consecutive dots)`
      );
    }
    const bracketMatch = part.match(/^(.+?)\[(\d+)\]$/);
    if (bracketMatch) {
      const name = bracketMatch[1];
      if (DANGEROUS_KEYS.has(name)) return null;
      const idx = parseInt(bracketMatch[2], 10);
      segments.push({ type: "index", name, idx });
    } else {
      if (DANGEROUS_KEYS.has(part)) return null;
      segments.push({ type: "key", name: part });
    }
  }
  return segments;
}
function setNestedValue(root, segments, value) {
  let current = root;
  for (let i = 0; i < segments.length; i++) {
    const seg = segments[i];
    const isLast = i === segments.length - 1;
    if (seg.type === "index") {
      if (!Array.isArray(current[seg.name])) {
        current[seg.name] = [];
      }
      if (isLast) {
        current[seg.name][seg.idx] = value;
      } else {
        const arr = current[seg.name];
        const next = segments[i + 1];
        if (arr[seg.idx] == null || typeof arr[seg.idx] !== "object") {
          arr[seg.idx] = next.type === "index" ? {} : {};
        }
        current = arr[seg.idx];
      }
    } else {
      if (isLast) {
        current[seg.name] = value;
      } else {
        const next = segments[i + 1];
        if (current[seg.name] == null || typeof current[seg.name] !== "object" || Array.isArray(current[seg.name])) {
          current[seg.name] = next.type === "index" ? {} : {};
        }
        current = current[seg.name];
      }
    }
  }
}
function parseSetFlags(setArgs) {
  const result = {};
  for (const arg of setArgs) {
    const eqIdx = arg.indexOf("=");
    if (eqIdx === -1) continue;
    const key = arg.substring(0, eqIdx).trim();
    const rawValue = arg.substring(eqIdx + 1);
    const value = coerceValue(rawValue);
    const segments = parseSegments(key);
    if (segments === null) continue;
    setNestedValue(result, segments, value);
  }
  return result;
}
function deepMergeSetOverrides(base, overrides) {
  for (const key of Object.keys(overrides)) {
    const ov = overrides[key];
    const bv = base[key];
    if (ov != null && typeof ov === "object" && !Array.isArray(ov) && bv != null && typeof bv === "object" && !Array.isArray(bv)) {
      deepMergeSetOverrides(
        bv,
        ov
      );
    } else {
      base[key] = ov;
    }
  }
  return base;
}
function coerceValue(raw) {
  if (raw === "true") return true;
  if (raw === "false") return false;
  if (raw === "0" || /^-?[1-9]\d*$/.test(raw)) return parseInt(raw, 10);
  if (raw.startsWith("[") && raw.endsWith("]") || raw.startsWith("{") && raw.endsWith("}")) {
    try {
      return JSON.parse(raw);
    } catch {
    }
  }
  return raw;
}

