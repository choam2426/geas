function loadLedger(root) {
  const p = debtsPath(root);
  const current = readJsonFile(p);
  if (current && Array.isArray(current.entries)) {
    return current;
  }
  const ts = nowUtc9();
  return { entries: [], created_at: ts, updated_at: ts };
}
function nextDebtId(entries) {
  let max = 0;
  for (const e of entries) {
    const id = typeof e.debt_id === "string" ? e.debt_id : "";
    const m = DEBT_ID_RE.exec(id);
    if (!m) continue;
    const n = parseInt(id.slice("debt-".length), 10);
    if (Number.isFinite(n) && n > max) max = n;
  }
  const next = max + 1;
  return `debt-${next.toString().padStart(3, "0")}`;
}
function registerRegister(debt) {
  debt.command("register").description(
    "Append a new entry to `.geas/debts.json` (project-level). Payload via --file or stdin: debt body (debt_id auto-assigned, status forced to open)."
  ).option("--file <path>", "Read JSON payload from file instead of stdin").action((opts) => {
    const root = needProjectRoot9();
    let payload;
    try {
      payload = readPayloadJson(opts.file);
    } catch (e) {
      if (e instanceof StdinError) emit(err("invalid_argument", e.message));
      throw e;
    }
    if (!payload || typeof payload !== "object" || Array.isArray(payload)) {
      emit(
        err(
          "invalid_argument",
          "debt register expects a JSON object payload (one entry body)"
        )
      );
    }
    const introduced = payload.introduced_by;
    if (!introduced || typeof introduced !== "object" || typeof introduced.mission_id !== "string" || typeof introduced.task_id !== "string") {
      emit(
        err(
          "invalid_argument",
          "introduced_by is required with mission_id and task_id (project-level ledger traces each debt back to its origin mission/task)"
        )
      );
    }
    if (!isValidMissionId(introduced.mission_id)) {
      emit(
        err(
          "invalid_argument",
          `invalid introduced_by.mission_id '${introduced.mission_id}'`
        )
      );
    }
    if (!isValidTaskId(introduced.task_id)) {
      emit(
        err(
          "invalid_argument",
          `invalid introduced_by.task_id '${introduced.task_id}'`
        )
      );
    }
    if (typeof payload.severity !== "string" || !SEVERITY_ENUM.has(payload.severity)) {
      emit(
        err(
          "invalid_argument",
          `severity must be one of ${[...SEVERITY_ENUM].join(", ")}`
        )
      );
    }
    if (typeof payload.kind !== "string" || !KIND_ENUM.has(payload.kind)) {
      emit(
        err(
          "invalid_argument",
          `kind must be one of ${[...KIND_ENUM].join(", ")}`
        )
      );
    }
    const ledger = loadLedger(root);
    const debtId = nextDebtId(ledger.entries);
    const entry = {
      debt_id: debtId,
      severity: payload.severity,
      kind: payload.kind,
      title: payload.title,
      description: payload.description,
      status: "open",
      introduced_by: {
        mission_id: introduced.mission_id,
        task_id: introduced.task_id
      },
      resolved_by: null,
      resolution_rationale: null
    };
    const ts = nowUtc9();
    const next = {
      entries: [...ledger.entries, entry],
      created_at: ledger.created_at || ts,
      updated_at: ts
    };
    const v = validate("debts", next);
    if (!v.ok) {
      emit(
        err(
          "schema_validation_failed",
          "debts schema validation failed",
          v.errors
        )
      );
    }
    const target = debtsPath(root);
    ensureDir(path12.dirname(target));
    atomicWriteJson(target, next, tmpDir(root));
    recordEvent(root, {
      kind: "debt_registered",
      actor: "cli:auto",
      payload: {
        artifact: slashPath8(path12.relative(root, target)),
        debt_id: debtId,
        mission_id: introduced.mission_id,
        task_id: introduced.task_id,
        severity: payload.severity,
        kind: payload.kind
      }
    });
    emit(
      ok({
        path: slashPath8(target),
        ids: { debt_id: debtId },
        entry
      })
    );
  });
}
function registerUpdateStatus(debt) {
  debt.command("update-status").description(
