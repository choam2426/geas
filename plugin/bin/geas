var SEVERITY_ENUM = /* @__PURE__ */ new Set(["low", "normal", "high", "critical"]);
var KIND_ENUM = /* @__PURE__ */ new Set([
  "output_quality",
  "verification_gap",
  "structural",
  "risk",
  "process",
  "documentation",
  "operations"
