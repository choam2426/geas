// src/commands/consolidation.ts
var fs10 = __toESM(require("fs"));
var path15 = __toESM(require("path"));
function nowUtc12() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
function slashPath11(p) {
  return p.replace(/\\/g, "/");
}
function needProjectRoot13() {
  const root = findProjectRoot(process.cwd());
  if (!root) {
    emit(
      err(
        "missing_artifact",
        `.geas/ not found at ${process.cwd().replace(/\\/g, "/")}. Run 'geas setup' first.`
      )
    );
  }
  return root;
}
var SCAFFOLD_PHASES = /* @__PURE__ */ new Set(["polishing", "consolidating"]);
function harvestFile(filePath, taskId, buckets) {
  const body = readJsonFile(filePath);
  if (!body || !Array.isArray(body.entries)) return;
  for (const rawEntry of body.entries) {
    if (!rawEntry || typeof rawEntry !== "object") continue;
    const entry = rawEntry;
    const entryId = typeof entry.entry_id === "number" ? entry.entry_id : void 0;
    if (entryId === void 0) continue;
    const dc = entry.debt_candidates;
    if (Array.isArray(dc)) {
      for (const item of dc) {
        if (!item || typeof item !== "object") continue;
        buckets.debt_candidates.push({
          source_task_id: taskId,
          source_evidence_entry_id: entryId,
          ...item
        });
      }
    }
    const ms = entry.memory_suggestions;
    if (Array.isArray(ms)) {
      for (const item of ms) {
        if (typeof item !== "string") continue;
        buckets.memory_suggestions.push({
          source_task_id: taskId,
          source_evidence_entry_id: entryId,
          suggestion: item
        });
      }
    }
    const gs = entry.gap_signals;
    if (Array.isArray(gs)) {
      for (const item of gs) {
        if (!item || typeof item !== "object") continue;
        buckets.gap_signals.push({
          source_task_id: taskId,
          source_evidence_entry_id: entryId,
          ...item
        });
      }
    }
  }
}
function registerScaffold(root) {
  root.command("scaffold").description(
    "Harvest debt_candidate / memory_suggestion / gap_signals fields from every task evidence file under a mission into consolidation/candidates.json (convenience cache, not a protocol artifact)."
  ).requiredOption("--mission <id>", "Mission ID").action((opts) => {
    if (!isValidMissionId(opts.mission)) {
      emit(err("invalid_argument", `invalid mission id '${opts.mission}'`));
    }
    const projectRoot = needProjectRoot13();
    if (!exists(missionSpecPath(projectRoot, opts.mission))) {
      emit(
        err(
          "missing_artifact",
          `mission spec not found for ${opts.mission}`
        )
      );
    }
    const state = readJsonFile(
      missionStatePath(projectRoot, opts.mission)
    );
    if (!state) {
      emit(
        err(
          "missing_artifact",
          `mission-state.json not found for ${opts.mission}`
        )
      );
    }
    const phase = state.phase ?? "";
    if (!SCAFFOLD_PHASES.has(phase)) {
      emit(
        err(
          "guard_failed",
          `consolidation scaffold requires mission phase polishing or consolidating (current: ${phase || "unknown"})`,
          { phase, allowed: [...SCAFFOLD_PHASES] }
        )
      );
    }
    const buckets = {
      debt_candidates: [],
      memory_suggestions: [],
      gap_signals: []
    };
    const tDir = tasksDir(projectRoot, opts.mission);
    if (exists(tDir)) {
      for (const taskDirName of fs10.readdirSync(tDir)) {
        if (!/^task-[0-9]{3}$/.test(taskDirName)) continue;
        const evDir = evidenceDir(projectRoot, opts.mission, taskDirName);
        if (!exists(evDir)) continue;
        for (const file of fs10.readdirSync(evDir)) {
          if (!file.endsWith(".json")) continue;
          const filePath = path15.join(evDir, file);
          harvestFile(filePath, taskDirName, buckets);
        }
      }
    }
    const target = missionCandidatesPath(projectRoot, opts.mission);
    const existing = readJsonFile(target);
    const ts = nowUtc12();
    const payload = {
      mission_id: opts.mission,
      debt_candidates: buckets.debt_candidates,
      memory_suggestions: buckets.memory_suggestions,
      gap_signals: buckets.gap_signals,
      created_at: existing?.created_at ?? ts,
      updated_at: ts
    };
    ensureDir(path15.dirname(target));
    atomicWriteJson(target, payload, tmpDir(projectRoot));
    recordEvent(projectRoot, {
      kind: "consolidation_scaffolded",
      actor: "cli:auto",
      payload: {
        mission_id: opts.mission,
        artifact: slashPath11(path15.relative(projectRoot, target)),
        counts: {
          debt_candidates: buckets.debt_candidates.length,
          memory_suggestions: buckets.memory_suggestions.length,
          gap_signals: buckets.gap_signals.length
        }
      }
    });
    emit(
      ok({
        path: slashPath11(target),
        ids: { mission_id: opts.mission },
        counts: {
          debt_candidates: buckets.debt_candidates.length,
          memory_suggestions: buckets.memory_suggestions.length,
          gap_signals: buckets.gap_signals.length
        },
        candidates: payload
      })
    );
  });
}
function registerConsolidationCommands(program2) {
  const root = program2.command("consolidation").description(
    "Consolidation-phase scaffolding (convenience cache for consolidating phase)."
  );
  registerScaffold(root);
}

// src/commands/impl-contract.ts
var path16 = __toESM(require("path"));
function nowUtc13() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
function slashPath12(p) {
  return p.replace(/\\/g, "/");
}
function needProjectRoot14() {
  const root = findProjectRoot(process.cwd());
  if (!root) {
    emit(
      err(
        "missing_artifact",
        `.geas/ not found at ${process.cwd().replace(/\\/g, "/")}. Run 'geas setup' first.`
      )
    );
  }
  return root;
}
var IMPL_CONTRACT_WRITABLE_STATES = /* @__PURE__ */ new Set(["implementing"]);
var ENVELOPE_FIELDS = ["mission_id", "task_id", "created_at", "updated_at"];
function registerImplContractCommands(program2) {
  const ic = program2.command("impl-contract").description(
    "Pre-implementation agreement (implementation-contract.json) commands."
  );
  ic.command("set").description(
    "Write implementation-contract.json for a task (full-replace; payload via --file or stdin). CLI injects mission_id / task_id / timestamps."
  ).requiredOption("--mission <id>", "Mission ID").requiredOption("--task <id>", "Task ID").option("--file <path>", "Read JSON payload from file instead of stdin").action((opts) => {
    if (!isValidMissionId(opts.mission)) {
      emit(err("invalid_argument", `invalid mission id '${opts.mission}'`));
    }
    if (!isValidTaskId(opts.task)) {
      emit(err("invalid_argument", `invalid task id '${opts.task}'`));
    }
    const root = needProjectRoot14();
    const spec = readJsonFile(
      missionSpecPath(root, opts.mission)
    );
    if (!spec) {
      emit(
        err(
          "missing_artifact",
          `mission spec not found for ${opts.mission}`
        )
      );
    }
    if (spec && spec.user_approved !== true) {
      emit(
        err(
          "guard_failed",
          `mission spec for ${opts.mission} is not user-approved; run 'geas mission approve' first`
        )
      );
    }
    const contract = readJsonFile(
      taskContractPath(root, opts.mission, opts.task)
    );
    if (!contract) {
      emit(
        err(
          "missing_artifact",
          `task contract not found for ${opts.task}`
        )
      );
    }
    if (contract && contract.approved_by == null) {
      emit(
        err(
          "guard_failed",
          `task ${opts.task} is not approved; run 'geas task approve' first`
        )
      );
    }
    const state = readJsonFile(
      taskStatePath(root, opts.mission, opts.task)
    );
    if (!state) {
      emit(
        err(
          "missing_artifact",
          `task-state.json not found for ${opts.task}`
        )
      );
    }
    const status = state.status ?? "";
    if (!IMPL_CONTRACT_WRITABLE_STATES.has(status)) {
      emit(
        err(
          "guard_failed",
          `impl-contract set requires task state implementing (current: ${status || "unknown"})`,
          { current_status: status, allowed: [...IMPL_CONTRACT_WRITABLE_STATES] }
        )
      );
    }
    let payload;
    try {
      payload = readPayloadJson(opts.file);
    } catch (e) {
      if (e instanceof StdinError) emit(err("invalid_argument", e.message));
      throw e;
    }
    if (!payload || typeof payload !== "object" || Array.isArray(payload)) {
      emit(
        err(
          "invalid_argument",
          "impl-contract set expects a JSON object on stdin"
        )
      );
    }
    for (const k of ENVELOPE_FIELDS) delete payload[k];
    if (payload.non_goals === void 0) payload.non_goals = [];
    if (payload.alternatives_considered === void 0) {
      payload.alternatives_considered = [];
    }
    if (payload.assumptions === void 0) payload.assumptions = [];
    if (payload.open_questions === void 0) payload.open_questions = [];
    const target = implementationContractPath(
      root,
      opts.mission,
      opts.task
    );
    const existing = readJsonFile(target);
    const ts = nowUtc13();
    payload.mission_id = opts.mission;
    payload.task_id = opts.task;
    payload.created_at = existing?.created_at ?? ts;
    payload.updated_at = ts;
    const v = validate("implementation-contract", payload);
    if (!v.ok) {
      emit(
        err(
          "schema_validation_failed",
          "implementation-contract schema validation failed",
          v.errors
        )
      );
    }
    ensureDir(path16.dirname(target));
    atomicWriteJson(target, payload, tmpDir(root));
    recordEvent(root, {
      kind: "impl_contract_set",
      actor: "cli:auto",
      payload: {
        mission_id: opts.mission,
        task_id: opts.task,
        artifact: slashPath12(path16.relative(root, target))
      }
    });
    emit(
      ok({
        path: slashPath12(target),
        ids: { mission_id: opts.mission, task_id: opts.task },
        implementation_contract: payload
      })
    );
  });
}

// src/main.ts
var VERSION = "0.13.0";
var GLOBAL_FLAG_FIELDS = ["json", "verbose", "debug"];
function makeGlobalFlagOption(field) {
  switch (field) {
    case "json":
      return new Option("--json", "emit machine-readable JSON envelope on stdout");
    case "verbose":
      return new Option("--verbose", "include extra context in human-readable output");
    case "debug":
      return new Option("--debug", "include diagnostic detail (pairs with --json)");
  }
}
function attachGlobalFlagsRecursive(cmd) {
  for (const field of GLOBAL_FLAG_FIELDS) {
    const flagName = `--${field}`;
    const alreadyRegistered = cmd.options.some((o) => o.long === flagName);
    if (!alreadyRegistered) {
      cmd.addOption(makeGlobalFlagOption(field));
    }
  }
  for (const sub of cmd.commands) {
    attachGlobalFlagsRecursive(sub);
  }
}
function resolveGlobalFlags(leaf) {
  let json = false;
  let verbose = false;
  let debug = false;
  const chain = [];
  let cursor = leaf;
  while (cursor) {
    chain.unshift(cursor);
    cursor = cursor.parent;
  }
  for (const node of chain) {
    const opts = node.opts();
    if (opts.json === true) json = true;
    if (opts.verbose === true) verbose = true;
    if (opts.debug === true) debug = true;
  }
  return {
    mode: json ? "json" : "default",
    verbose,
    debug
  };
}
function installFlagPropagationHooks(cmd) {
  cmd.hook("preAction", (_thisCommand, actionCommand) => {
    setOutputMode(resolveGlobalFlags(actionCommand));
  });
  for (const sub of cmd.commands) {
    installFlagPropagationHooks(sub);
  }
}
function run() {
  const program2 = new Command();
  program2.name("geas").description("Geas CLI \u2014 atomic actuator for .geas/ runtime artifacts").version(VERSION);
  registerSetupCommand(program2);
  registerContextCommand(program2);
  registerSchemaCommands(program2);
  registerStateCommands(program2);
  registerMissionCommands(program2);
  registerTaskCommands(program2);
  registerEvidenceCommands(program2);
  registerSelfCheckCommands(program2);
  registerDeliberationCommands(program2);
  registerGateCommands(program2);
  registerMemoryCommands(program2);
  registerDebtCommands(program2);
  registerGapCommands(program2);
  registerMemoryUpdateCommands(program2);
  registerEventCommands(program2);
  registerConsolidationCommands(program2);
  registerImplContractCommands(program2);
  attachGlobalFlagsRecursive(program2);
  installFlagPropagationHooks(program2);
  program2.parse(process.argv);
}

// src/bundle-entry.ts
run();
