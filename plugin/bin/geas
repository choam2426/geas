function registerSelfCheckCommands(program2) {
  const sc = program2.command("self-check").description("Implementer self-check artifact (self-check.json) commands.");
  sc.command("append").description(
    "Append a self-check entry for a task (payload via --file or stdin: entry content fields). Creates the file on first append; subsequent appends push new entries to entries[]. One entry per implementer pass."
  ).requiredOption("--mission <id>", "Mission ID").requiredOption("--task <id>", "Task ID").option("--file <path>", "Read JSON payload from file instead of stdin").action((opts) => {
    if (!isValidMissionId(opts.mission)) {
      emit(err("invalid_argument", `invalid mission id '${opts.mission}'`));
    }
    if (!isValidTaskId(opts.task)) {
      emit(err("invalid_argument", `invalid task id '${opts.task}'`));
    }
    const root = needProjectRoot5();
    if (!exists(missionSpecPath(root, opts.mission))) {
      emit(
        err(
          "missing_artifact",
          `mission spec not found for ${opts.mission}`
        )
      );
    }
    if (!exists(taskContractPath(root, opts.mission, opts.task))) {
      emit(
        err(
          "missing_artifact",
          `task contract not found for ${opts.task}`
        )
      );
    }
    let payload;
    try {
      payload = readPayloadJson(opts.file);
    } catch (e) {
      if (e instanceof StdinError) emit(err("invalid_argument", e.message));
      throw e;
    }
    if (!payload || typeof payload !== "object" || Array.isArray(payload)) {
      emit(
        err(
          "invalid_argument",
          "self-check append expects a JSON object on stdin"
        )
      );
    }
    if (payload.reviewer_focus === void 0) payload.reviewer_focus = [];
    if (payload.known_risks === void 0) payload.known_risks = [];
    if (payload.deviations_from_plan === void 0) {
      payload.deviations_from_plan = [];
    }
    if (payload.gap_signals === void 0) payload.gap_signals = [];
    if (payload.revision_ref === void 0) payload.revision_ref = null;
    delete payload.entry_id;
    delete payload.created_at;
    const p = selfCheckPath(root, opts.mission, opts.task);
    const ts = nowUtc6();
    const existing = readJsonFile(p);
    const nextEntryId2 = existing && Array.isArray(existing.entries) ? existing.entries.length + 1 : 1;
    const entry = {
      entry_id: nextEntryId2,
      ...payload,
      created_at: ts
    };
    const merged = {
      mission_id: opts.mission,
      task_id: opts.task,
      entries: existing && Array.isArray(existing.entries) ? [...existing.entries, entry] : [entry],
      created_at: existing?.created_at ?? ts,
      updated_at: ts
    };
    const v = validate("self-check", merged);
    if (!v.ok) {
      emit(
        err(
          "schema_validation_failed",
          "self-check schema validation failed",
          v.errors
        )
      );
    }
    ensureDir(path8.dirname(p));
    atomicWriteJson(p, merged, tmpDir(root));
    recordEvent(root, {
      kind: "self_check_appended",
      actor: "cli:auto",
      payload: {
        mission_id: opts.mission,
        task_id: opts.task,
        artifact: slashPath4(path8.relative(root, p)),
        entry_id: nextEntryId2
      }
    });
    emit(
      ok({
        path: slashPath4(p),
        ids: {
          mission_id: opts.mission,
          task_id: opts.task,
          entry_id: nextEntryId2
        },
        self_check: merged
      })
    );
  });
}

// src/commands/deliberation.ts
var path9 = __toESM(require("path"));
function nowUtc7() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
function slashPath5(p) {
  return p.replace(/\\/g, "/");
}
function needProjectRoot6() {
  const root = findProjectRoot(process.cwd());
  if (!root) {
    emit(
      err(
        "missing_artifact",
        `.geas/ not found at ${process.cwd().replace(/\\/g, "/")}. Run 'geas setup' first.`
      )
    );
  }
  return root;
}
function aggregateExpected(votes) {
  if (!Array.isArray(votes) || votes.length < 2) return "inconclusive";
  let agree = 0, disagree = 0, escalate = 0;
  for (const v of votes) {
    if (v && v.vote === "escalate") escalate++;
    else if (v && v.vote === "agree") agree++;
    else if (v && v.vote === "disagree") disagree++;
  }
  if (escalate > 0) return "escalate";
  if (agree > disagree) return "agree";
  if (disagree > agree) return "disagree";
  return "inconclusive";
}
function registerDeliberationAppend(cmd) {
  cmd.command("append").description(
    "Append a deliberation entry. Requires mission mode = full_depth."
  ).requiredOption("--mission <id>", "Mission ID").requiredOption("--level <level>", '"mission" or "task"').option("--task <id>", "Task ID (required when --level task)").option("--file <path>", "Read JSON payload from file instead of stdin").action(
    (opts) => {
      if (!isValidMissionId(opts.mission)) {
        emit(err("invalid_argument", `invalid mission id '${opts.mission}'`));
      }
      if (opts.level !== "mission" && opts.level !== "task") {
        emit(err("invalid_argument", `--level must be 'mission' or 'task'`));
      }
      if (opts.level === "task") {
        if (!opts.task || !isValidTaskId(opts.task)) {
          emit(
            err(
              "invalid_argument",
              "--task <id> is required when --level is task"
            )
          );
        }
      } else if (opts.task) {
        emit(
          err(
            "invalid_argument",
            "--task must not be set when --level is mission"
          )
        );
      }
      const root = needProjectRoot6();
      const spec = readJsonFile(
        missionSpecPath(root, opts.mission)
      );
      if (!spec) {
        emit(
          err(
            "missing_artifact",
            `mission spec not found for ${opts.mission}`
          )
        );
      }
      const mode = typeof spec.mode === "string" ? spec.mode : "";
      if (mode !== "full_depth") {
        emit(
          err(
            "guard_failed",
            `deliberation is only permitted when mission mode is 'full_depth' (mission '${opts.mission}' mode is '${mode || "unset"}')`,
            { mission_mode: mode || null, required_mode: "full_depth" }
          )
        );
      }
      let payload;
      try {
        payload = readPayloadJson(opts.file);
      } catch (e) {
        if (e instanceof StdinError) emit(err("invalid_argument", e.message));
        throw e;
      }
      if (!payload || typeof payload !== "object" || Array.isArray(payload)) {
        emit(
          err(
            "invalid_argument",
            "deliberation append expects a JSON object payload"
          )
        );
      }
      delete payload.created_at;
      payload.created_at = nowUtc7();
      const votes = Array.isArray(payload.votes) ? payload.votes : [];
      const expectedResult = aggregateExpected(votes);
      const providedResult = typeof payload.result === "string" ? payload.result : "";
      if (providedResult !== expectedResult) {
        emit(
          err(
            "guard_failed",
            `deliberation result '${providedResult || "(unset)"}' is inconsistent with votes; expected '${expectedResult}' per protocol 03 aggregation rule`,
            {
              expected_result: expectedResult,
              provided_result: providedResult || null
            }
          )
        );
      }
      const filePath = opts.level === "mission" ? missionDeliberationsPath(root, opts.mission) : taskDeliberationsPath(root, opts.mission, opts.task);
      const existing = readJsonFile(filePath);
      const ts = nowUtc7();
      const merged = {
        mission_id: opts.mission,
        level: opts.level,
        ...opts.level === "task" ? { task_id: opts.task } : {},
        entries: existing && Array.isArray(existing.entries) ? [...existing.entries, payload] : [payload],
        created_at: existing?.created_at ?? ts,
        updated_at: ts
      };
      const v = validate("deliberation", merged);
      if (!v.ok) {
        emit(
          err(
            "schema_validation_failed",
            "deliberation schema validation failed",
            v.errors
          )
        );
      }
      ensureDir(path9.dirname(filePath));
      atomicWriteJson(filePath, merged, tmpDir(root));
      recordEvent(root, {
        kind: "deliberation_appended",
        actor: "cli:auto",
        payload: {
          mission_id: opts.mission,
          task_id: opts.task ?? null,
          level: opts.level,
          artifact: slashPath5(path9.relative(root, filePath)),
          result: expectedResult
        }
      });
      emit(
        ok({
          path: slashPath5(filePath),
          ids: {
            mission_id: opts.mission,
            task_id: opts.task ?? null
          },
          level: opts.level,
          result: expectedResult,
          entries_count: merged.entries.length
        })
      );
    }
  );
}
function registerDeliberationCommands(program2) {
  const d = program2.command("deliberation").description(
    "Append-only deliberation log. Mission or task level. Requires full_depth mode."
  );
  registerDeliberationAppend(d);
}

// src/commands/gate.ts
var fs9 = __toESM(require("fs"));
var path10 = __toESM(require("path"));
function nowUtc8() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
function slashPath6(p) {
  return p.replace(/\\/g, "/");
}
function needProjectRoot7() {
  const root = findProjectRoot(process.cwd());
  if (!root) {
    emit(
      err(
        "missing_artifact",
        `.geas/ not found at ${process.cwd().replace(/\\/g, "/")}. Run 'geas setup' first.`
      )
    );
  }
  return root;
}
function overallFromTiers(tier0, tier1, tier2) {
  for (const s of [tier0, tier1, tier2]) {
    if (s === "error") return "error";
    if (s === "block") return "block";
    if (s === "fail") return "fail";
  }
  return "pass";
}
function worstStatus(statuses) {
  if (statuses.length === 0) return "error";
  const order = {
    error: 4,
    block: 3,
    fail: 2,
    pass: 1,
    skipped: 0
  };
  let worst = "pass";
  for (const s of statuses) {
    if (order[s] > order[worst]) worst = s;
  }
  return worst;
}
function listEvidenceFilesForSlot(root, missionId, taskId, slot) {
  const dir = evidenceDir(root, missionId, taskId);
  if (!exists(dir)) return [];
  const suffix = `.${slot}.json`;
  return fs9.readdirSync(dir).filter((f) => f.endsWith(suffix)).map((f) => path10.join(dir, f));
}
function readEvidenceFile(filePath) {
  return readJsonFile(filePath);
}
function latestEntryOfKind(file, kind) {
  if (!file || !Array.isArray(file.entries)) return null;
  for (let i = file.entries.length - 1; i >= 0; i--) {
    const e = file.entries[i];
    if (e && e.evidence_kind === kind) return e;
  }
  return null;
}
function computeTier0(root, missionId, taskId, contract, taskState) {
  const fails = [];
  const notes = [];
  if (!taskState) {
    fails.push("task-state.json missing");
  } else if (taskState.status !== "reviewing") {
    fails.push(
      `task-state.status is '${taskState.status}'; gate requires 'reviewing'`
    );
  }
  const implPath = implementationContractPath(root, missionId, taskId);
  if (!exists(implPath)) {
    fails.push("implementation-contract.json missing");
  } else {
    const impl = readJsonFile(implPath);
    const v = validate("implementation-contract", impl);
    if (!v.ok) {
      fails.push("implementation-contract.json schema-invalid");
    } else {
      notes.push("implementation-contract.json present and valid");
    }
  }
  const scPath = selfCheckPath(root, missionId, taskId);
  if (!exists(scPath)) {
    fails.push("self-check.json missing");
  } else {
    const sc = readJsonFile(scPath);
    const v = validate("self-check", sc);
    if (!v.ok) {
      fails.push("self-check.json schema-invalid");
    } else {
      notes.push("self-check.json present and valid");
    }
  }
  const required = Array.isArray(contract.routing?.required_reviewers) ? contract.routing.required_reviewers : [];
  for (const slot of required) {
    const files = listEvidenceFilesForSlot(root, missionId, taskId, slot);
    if (files.length === 0) {
      fails.push(`reviewer slot '${slot}': no evidence/*.${slot}.json file`);
      continue;
    }
    let sawValidReview = false;
    for (const fp of files) {
      const ef = readEvidenceFile(fp);
      const last = latestEntryOfKind(ef, "review");
      if (last && typeof last.verdict === "string" && ["approved", "changes_requested", "blocked"].includes(last.verdict)) {
        sawValidReview = true;
        notes.push(
          `reviewer '${slot}': ${path10.basename(fp)} entry_id=${last.entry_id} verdict=${last.verdict}`
        );
        break;
      }
    }
    if (!sawValidReview) {
      fails.push(
        `reviewer slot '${slot}': no valid review-kind entry with verdict in {approved, changes_requested, blocked}`
      );
    }
  }
  if (fails.length > 0) {
    return {
      status: "fail",
      details: `Tier 0 fail: ${fails.join("; ")}`
    };
  }
  return {
    status: "pass",
    details: `Tier 0 pass. ${notes.join("; ")}`
  };
}
function computeTier1(root, missionId, taskId) {
  const verifierFiles = listEvidenceFilesForSlot(
    root,
    missionId,
    taskId,
    "verifier"
  );
  if (verifierFiles.length === 0) {
    return {
      status: "error",
      details: "Tier 1 error: no evidence/*.verifier.json file found. Verifier must append a verification-kind entry before the gate runs."
    };
  }
  const perFile = [];
  for (const fp of verifierFiles) {
    const ef = readEvidenceFile(fp);
    const last = latestEntryOfKind(ef, "verification");
    const base = path10.basename(fp);
    if (!last) {
      perFile.push({
        file: fp,
        status: "error",
        note: `${base}: no verification-kind entry`
      });
      continue;
    }
    const verdict = last.verdict;
    const criteria = Array.isArray(last.criteria_results) ? last.criteria_results : [];
    if (verdict === "approved" && criteria.some((c) => c.passed !== true)) {
      const failedCount = criteria.filter((c) => c.passed !== true).length;
      perFile.push({
        file: fp,
        status: "error",
        note: `${base}: verdict=approved but ${failedCount}/${criteria.length} criteria have passed=false (internal contradiction)`
      });
      continue;
    }
    let status2;
    if (verdict === "approved") status2 = "pass";
    else if (verdict === "changes_requested") status2 = "fail";
    else if (verdict === "blocked") status2 = "block";
    else {
      perFile.push({
        file: fp,
        status: "error",
        note: `${base}: entry_id=${last.entry_id} has no recognized verdict`
      });
      continue;
    }
    const passedCount = criteria.filter((c) => c.passed === true).length;
    perFile.push({
      file: fp,
      status: status2,
      note: `${base}: entry_id=${last.entry_id} verdict=${verdict} criteria=${passedCount}/${criteria.length}`
    });
  }
  const status = worstStatus(perFile.map((p) => p.status));
  const details = `Tier 1 ${status}: ${perFile.map((p) => p.note).join("; ")}`;
  return { status, details };
}
function computeTier2(root, missionId, taskId, contract) {
  const required = Array.isArray(contract.routing?.required_reviewers) ? contract.routing.required_reviewers : [];
  if (required.length === 0) {
    return {
      status: "pass",
      details: "Tier 2 pass: no required reviewers declared in contract."
    };
  }
  const verdicts = [];
  for (const slot of required) {
    const files = listEvidenceFilesForSlot(root, missionId, taskId, slot);
    let picked = null;
    for (const fp of files) {
      const ef = readEvidenceFile(fp);
      const last = latestEntryOfKind(ef, "review");
      if (last && typeof last.verdict === "string" && ["approved", "changes_requested", "blocked"].includes(last.verdict)) {
        picked = { verdict: last.verdict, file: path10.basename(fp) };
        break;
      }
    }
    verdicts.push({
      slot,
      verdict: picked ? picked.verdict : null,
      file: picked ? picked.file : null
    });
  }
  const missing = verdicts.filter((v) => v.verdict === null);
  if (missing.length > 0) {
    return {
      status: "error",
      details: `Tier 2 error: missing reviewer verdicts for ${missing.map((v) => v.slot).join(", ")}.`
    };
  }
  const anyBlocked = verdicts.some((v) => v.verdict === "blocked");
  if (anyBlocked) {
    return {
      status: "block",
      details: `Tier 2 block: ${verdicts.map((v) => `${v.slot}=${v.verdict}`).join(", ")}`
    };
  }
  const anyChanges = verdicts.some((v) => v.verdict === "changes_requested");
  if (anyChanges) {
    return {
      status: "fail",
      details: `Tier 2 fail: ${verdicts.map((v) => `${v.slot}=${v.verdict}`).join(", ")}`
    };
  }
  return {
    status: "pass",
    details: `Tier 2 pass: ${verdicts.map((v) => `${v.slot}=approved (${v.file})`).join(", ")}`
  };
}
function registerGateRun(cmd) {
  cmd.command("run").description(
    "Record an evidence gate run. Reads task artifacts directly and computes tier statuses itself \u2014 no stdin payload."
  ).requiredOption("--mission <id>", "Mission ID").requiredOption("--task <id>", "Task ID").action((opts) => {
    if (!isValidMissionId(opts.mission)) {
      emit(err("invalid_argument", `invalid mission id '${opts.mission}'`));
    }
    if (!isValidTaskId(opts.task)) {
      emit(err("invalid_argument", `invalid task id '${opts.task}'`));
    }
    const root = needProjectRoot7();
    if (!exists(missionSpecPath(root, opts.mission))) {
      emit(
        err(
          "missing_artifact",
          `mission spec not found for ${opts.mission}`
        )
      );
    }
    const contractPath = taskContractPath(root, opts.mission, opts.task);
    if (!exists(contractPath)) {
      emit(
        err("missing_artifact", `task contract not found for ${opts.task}`)
      );
    }
    const contract = readJsonFile(contractPath);
    if (!contract) {
      emit(
        err(
          "missing_artifact",
          `task contract unreadable for ${opts.task}`
        )
      );
    }
    const taskState = readJsonFile(
      taskStatePath(root, opts.mission, opts.task)
    );
    const tier0 = computeTier0(
      root,
      opts.mission,
      opts.task,
      contract,
      taskState
    );
    const tier1 = computeTier1(root, opts.mission, opts.task);
    const tier2 = computeTier2(
      root,
      opts.mission,
      opts.task,
      contract
    );
    const overall = overallFromTiers(tier0.status, tier1.status, tier2.status);
    const filePath = gateResultsPath(root, opts.mission, opts.task);
    const existing = readJsonFile(filePath);
    const nextRunN = existing && Array.isArray(existing.runs) ? existing.runs.length + 1 : 1;
    const gateRunId = `gate-${nextRunN}`;
    const ts = nowUtc8();
    const run2 = {
      gate_run_id: gateRunId,
      verdict: overall,
      tier_results: {
        tier_0: tier0,
        tier_1: tier1,
        tier_2: tier2
      },
      created_at: ts
    };
    const merged = {
      mission_id: opts.mission,
      task_id: opts.task,
      runs: existing && Array.isArray(existing.runs) ? [...existing.runs, run2] : [run2],
      created_at: existing?.created_at ?? ts,
      updated_at: ts
    };
    const v = validate("gate-results", merged);
    if (!v.ok) {
      emit(
        err(
          "schema_validation_failed",
          "gate-results schema validation failed",
          v.errors
        )
      );
    }
    ensureDir(path10.dirname(filePath));
    atomicWriteJson(filePath, merged, tmpDir(root));
    recordEvent(root, {
      kind: "gate_run_recorded",
      actor: "cli:auto",
      payload: {
        mission_id: opts.mission,
        task_id: opts.task,
        artifact: slashPath6(path10.relative(root, filePath)),
        gate_run_id: gateRunId,
        verdict: overall
      }
    });
    const suggested = {
      verdict: overall,
      target_state: null,
      command: null
    };
    if (overall === "pass") {
      suggested.target_state = "deciding";
      suggested.command = `geas task transition --mission ${opts.mission} --task ${opts.task} --to deciding`;
    } else if (overall === "block") {
      suggested.target_state = "blocked";
      suggested.command = `geas task transition --mission ${opts.mission} --task ${opts.task} --to blocked`;
    }
    emit(
      ok({
        path: slashPath6(filePath),
        ids: {
          mission_id: opts.mission,
          task_id: opts.task,
          gate_run_id: gateRunId
        },
        verdict: overall,
        tier_results: run2.tier_results,
        suggested_next_transition: suggested,
        runs_count: merged.runs.length
      })
    );
  });
}
function registerGateCommands(program2) {
  const g = program2.command("gate").description("Evidence gate run recording (gate-results.json).");
  registerGateRun(g);
}

