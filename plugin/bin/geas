var UNDERSCORE_TO_HYPHEN = {
  task_contract: "task-contract",
  mission_spec: "mission-spec",
  design_brief: "design-brief",
  phase_review: "phase-review"
};
function normalizeKey(key) {
  return UNDERSCORE_TO_HYPHEN[key] || key;
}
function getEnvelopeFields(schemaName) {
  const policies = FIELD_POLICIES[normalizeKey(schemaName)];
  if (!policies) return /* @__PURE__ */ new Set();
  const result = /* @__PURE__ */ new Set();
  for (const [field, policy] of Object.entries(policies)) {
    if (field === "_envelope") continue;
    if (policy.class === "system" || policy.class === "derived") {
      result.add(field);
    }
  }
  return result;
}
function getCliFlagFields(schemaName) {
  const policies = FIELD_POLICIES[normalizeKey(schemaName)];
  if (!policies) return /* @__PURE__ */ new Set();
  const result = /* @__PURE__ */ new Set();
  for (const [field, policy] of Object.entries(policies)) {
    if (field === "_envelope") continue;
    if (policy.class === "guarded") {
      result.add(field);
    }
  }
  return result;
}
function getStrippableFields(schemaName) {
  const envelope = getEnvelopeFields(schemaName);
  const cliFlags = getCliFlagFields(schemaName);
  return /* @__PURE__ */ new Set([...envelope, ...cliFlags]);
}
function getEnvelopeEntry(artifactType) {
  const key = normalizeKey(artifactType);
  const policies = FIELD_POLICIES[key];
  if (!policies) return void 0;
  const envelopeMeta = policies._envelope;
  if (!envelopeMeta) return void 0;
  const injectData = envelopeMeta.inject;
  return {
    version: injectData.version,
    artifact_type: injectData.artifact_type,
    producer_type: injectData.producer_type,
    artifact_id_fn: envelopeMeta.id_fn
  };
}

// src/lib/envelope.ts
function injectEnvelope(artifactType, data, context) {
  const entry = getEnvelopeEntry(artifactType);
  if (!entry) return data;
  if (data.version === void 0) data.version = entry.version;
  if (data.artifact_type === void 0) data.artifact_type = entry.artifact_type;
  if (data.producer_type === void 0) data.producer_type = entry.producer_type;
  if (data.artifact_id === void 0) {
    data.artifact_id = entry.artifact_id_fn(data, context || {});
  }
  return data;
}

// src/lib/dry-run.ts
function dryRunGuard(dryRun, data, schemaName) {
  if (!dryRun) return;
  if (schemaName === null) {
    const result = {
      dry_run: true,
      valid: true,
      schema: null,
      note: "no schema validation for this command"
    };
    process.stdout.write(JSON.stringify(result) + "\n");
    process.exit(0);
    return;
  }
  const validation = validate(schemaName, data);
  if (validation.valid) {
    const result = {
      dry_run: true,
      valid: true,
      schema: schemaName
    };
    process.stdout.write(JSON.stringify(result) + "\n");
    process.exit(0);
  } else {
    const result = {
      dry_run: true,
      valid: false,
      schema: schemaName,
      errors: validation.errors || []
    };
    process.stdout.write(JSON.stringify(result) + "\n");
    process.exit(1);
  }
}
function dryRunParseError(errorMessage) {
  const result = {
    dry_run: true,
    valid: false,
    error: errorMessage
  };
  process.stdout.write(JSON.stringify(result) + "\n");
  process.exit(1);
}

// src/commands/mission.ts
function generateMissionId() {
  const now = /* @__PURE__ */ new Date();
  const y = now.getUTCFullYear();
  const m = String(now.getUTCMonth() + 1).padStart(2, "0");
  const d = String(now.getUTCDate()).padStart(2, "0");
  const date = `${y}${m}${d}`;
  const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
  const bytes = crypto.randomBytes(8);
  let rand = "";
  for (let i = 0; i < 8; i++) {
    rand += chars[bytes[i] % chars.length];
  }
  return `mission-${date}-${rand}`;
}
var MISSION_SUBDIRS = [
  "tasks",
  "decisions/pending",
  "polishing",
  "evolution",
  "phase-reviews"
];
function registerMissionCommands(program2) {
  const cmd = program2.command("mission").description("Mission CRUD (spec, design-brief, directory)");
  cmd.command("create").description("Create a mission directory with full subdirectory structure. Auto-generates ID if --id is omitted.").option("--id <mission-id>", "Mission identifier (auto-generated if omitted)").action((opts) => {
    try {
      const geasDir2 = resolveGeasDir(getCwd(cmd));
      const missionsDir = path5.resolve(geasDir2, "missions");
      let missionId;
      if (opts.id) {
        validateIdentifier(opts.id, "mission ID");
        missionId = opts.id;
      } else {
        let attempts = 0;
        do {
          missionId = generateMissionId();
          attempts++;
          if (attempts > 10) {
            fileError("", "create", "Failed to generate unique mission ID after 10 attempts");
            return;
          }
        } while (fs6.existsSync(path5.resolve(missionsDir, missionId)));
      }
      const missionDir = path5.resolve(missionsDir, missionId);
      const normalized = normalizePath(missionDir);
      if (fs6.existsSync(missionDir)) {
        fileError(normalized, "create", `Mission directory already exists: ${normalized}`);
        return;
      }
      ensureDir(missionDir);
      for (const sub of MISSION_SUBDIRS) {
        ensureDir(path5.resolve(missionDir, sub));
      }
      success({
        created: normalized,
        mission_id: missionId,
        subdirectories: MISSION_SUBDIRS
      });
    } catch (err) {
      const nodeErr = err;
      if (nodeErr.code === "FILE_ERROR") {
        fileError("", "create", nodeErr.message);
      } else {
        throw err;
      }
    }
  });
  cmd.command("write-spec").description("Write spec.json with schema validation (JSON via stdin)").requiredOption("--id <mission-id>", "Mission identifier").option("--dry-run", "Validate input without writing files").action((opts) => {
    try {
      validateIdentifier(opts.id, "mission ID");
      const cwd = getCwd(cmd);
      const geasDir2 = resolveGeasDir(cwd);
      const missionDir = path5.resolve(geasDir2, "missions", opts.id);
      if (!fs6.existsSync(missionDir)) {
        fileError(
          normalizePath(missionDir),
          "write",
          `Mission directory not found: ${normalizePath(missionDir)}. Run 'geas mission create --id ${opts.id}' first.`
        );
        return;
      }
      const data = readInputData();
      injectEnvelope("mission_spec", data, { mission_id: opts.id });
      if (opts.dryRun) {
        dryRunGuard(true, data, "mission-spec");
        return;
      }
      const result = validate("mission-spec", data);
      if (!result.valid) {
        validationError("mission-spec", result.errors);
        return;
      }
      const specPath = path5.resolve(missionDir, "spec.json");
      writeJsonFile(specPath, data, { cwd });
      success({
        written: normalizePath(specPath),
        mission_id: opts.id,
        artifact_type: "mission_spec"
      });
    } catch (err) {
      const nodeErr = err;
      if (nodeErr.code === "NO_STDIN") {
        noStdinError("mission write", nodeErr.message);
      } else if (nodeErr.code === "INVALID_JSON") {
        if (opts.dryRun) {
          dryRunParseError(nodeErr.message);
          return;
        }
        fileError("", "parse", nodeErr.message);
      } else if (nodeErr.code === "FILE_ERROR") {
        fileError("", "write", nodeErr.message);
      } else {
        throw err;
      }
    }
  });
  cmd.command("write-brief").description("Write design-brief.json with schema validation (JSON via stdin)").requiredOption("--id <mission-id>", "Mission identifier").option("--dry-run", "Validate input without writing files").action((opts) => {
    try {
      validateIdentifier(opts.id, "mission ID");
      const cwd = getCwd(cmd);
      const geasDir2 = resolveGeasDir(cwd);
      const missionDir = path5.resolve(geasDir2, "missions", opts.id);
      if (!fs6.existsSync(missionDir)) {
        fileError(
          normalizePath(missionDir),
          "write",
          `Mission directory not found: ${normalizePath(missionDir)}. Run 'geas mission create --id ${opts.id}' first.`
        );
        return;
      }
      const data = readInputData();
      injectEnvelope("design_brief", data, { mission_id: opts.id });
      if (opts.dryRun) {
        dryRunGuard(true, data, "design-brief");
        return;
      }
      const result = validate("design-brief", data);
      if (!result.valid) {
        validationError("design-brief", result.errors);
        return;
      }
      const briefPath = path5.resolve(missionDir, "design-brief.json");
      writeJsonFile(briefPath, data, { cwd });
      success({
        written: normalizePath(briefPath),
        mission_id: opts.id,
        artifact_type: "design_brief"
      });
    } catch (err) {
      const nodeErr = err;
      if (nodeErr.code === "NO_STDIN") {
        noStdinError("mission write", nodeErr.message);
      } else if (nodeErr.code === "INVALID_JSON") {
        if (opts.dryRun) {
          dryRunParseError(nodeErr.message);
          return;
        }
        fileError("", "parse", nodeErr.message);
      } else if (nodeErr.code === "FILE_ERROR") {
        fileError("", "write", nodeErr.message);
      } else {
        throw err;
      }
    }
  });
  cmd.command("read").description("Read mission artifacts (spec.json, design-brief.json, or both)").requiredOption("--id <mission-id>", "Mission identifier").option("--artifact <type>", "Artifact to read: spec, brief, or omit for both").action((opts) => {
    try {
      validateIdentifier(opts.id, "mission ID");
      const geasDir2 = resolveGeasDir(getCwd(cmd));
      const missionDir = path5.resolve(geasDir2, "missions", opts.id);
      if (!fs6.existsSync(missionDir)) {
        fileError(
          normalizePath(missionDir),
          "read",
          `Mission directory not found: ${normalizePath(missionDir)}`
        );
        return;
      }
      const artifactType = opts.artifact;
      if (artifactType && !["spec", "brief"].includes(artifactType)) {
        fileError("", "read", `Unknown artifact type '${artifactType}'. Use 'spec' or 'brief'.`);
        return;
      }
      const result = { mission_id: opts.id };
      if (!artifactType || artifactType === "spec") {
        const specPath = path5.resolve(missionDir, "spec.json");
        const spec = readJsonFile(specPath);
        if (spec) {
          result.spec = spec;
        } else if (artifactType === "spec") {
          fileError(normalizePath(specPath), "read", "spec.json not found");
          return;
        }
      }
      if (!artifactType || artifactType === "brief") {
        const briefPath = path5.resolve(missionDir, "design-brief.json");
        const brief = readJsonFile(briefPath);
        if (brief) {
          result.brief = brief;
        } else if (artifactType === "brief") {
          fileError(normalizePath(briefPath), "read", "design-brief.json not found");
          return;
        }
      }
      success(result);
    } catch (err) {
      const nodeErr = err;
      if (nodeErr.code === "FILE_ERROR") {
        fileError("", "read", nodeErr.message);
      } else {
        throw err;
      }
    }
  });
}

