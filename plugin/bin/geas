  ).requiredOption("--debt <id>", "Debt ID (debt-NNN)").option("--file <path>", "Read JSON payload from file instead of stdin").action((opts) => {
    if (!DEBT_ID_RE.test(opts.debt)) {
      emit(
        err(
          "invalid_argument",
          `invalid debt id '${opts.debt}' (expected ^debt-[0-9]{3}$)`
        )
      );
    }
