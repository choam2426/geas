// src/commands/setup.ts
var COMMAND_NAME = "setup";
function nowUtc() {
  return (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
}
function registerSetupCommand(program2) {
  program2.command(COMMAND_NAME).description("Initialize the .geas/ runtime tree for the current project").action(() => {
    try {
      const root = process.cwd();
      const created = [];
      const existed = [];
      const recordDir = (p) => {
        if (!exists(p)) {
          ensureDir(p);
          created.push(relToRoot(root, p));
        } else {
          existed.push(relToRoot(root, p));
        }
      };
      const recordFile = (p, writer) => {
        if (!exists(p)) {
          writer();
          created.push(relToRoot(root, p));
        } else {
          existed.push(relToRoot(root, p));
        }
      };
      recordDir(geasDir(root));
      recordDir(memoryDir(root));
      recordDir(agentsMemoryDir(root));
      recordDir(missionsDir(root));
      recordDir(tmpDir(root));
      recordFile(configPath(root), () => {
        atomicWriteJson(configPath(root), {
          created_at: nowUtc()
        });
      });
      recordFile(debtsPath(root), () => {
        const ts = nowUtc();
        atomicWriteJson(debtsPath(root), {
          entries: [],
          created_at: ts,
          updated_at: ts
        });
      });
      recordFile(eventsPath(root), () => {
        atomicWrite(eventsPath(root), "");
      });
      recordFile(sharedMemoryPath(root), () => {
        atomicWrite(sharedMemoryPath(root), "");
      });
      emitOk(COMMAND_NAME, {
        project_root: root.replace(/\\/g, "/"),
        geas_dir: geasDir(root).replace(/\\/g, "/"),
        created,
        existed
      });
    } catch (e) {
      const msg = e instanceof Error ? e.message : String(e);
      emitErr(
        makeError("io_error", `setup failed: ${msg}`, {
          hint: "check filesystem permissions and that the project directory is writable",
          exit_category: "io"
        })
      );
    }
  });
}
function relToRoot(root, target) {
  return path3.relative(root, target).replace(/\\/g, "/");
}

// src/commands/context.ts
var fs3 = __toESM(require("fs"));
var COMMAND_NAME2 = "context";
function registerContextCommand(program2) {
  program2.command(COMMAND_NAME2).description("Print a JSON summary of the current .geas/ state").action(() => {
    const root = findProjectRoot(process.cwd());
    if (!root) {
      emitErr(
        makeError(
          "missing_artifact",
          `.geas/ not found at ${process.cwd().replace(/\\/g, "/")}.`,
          {
            hint: "run 'geas setup' to bootstrap the .geas/ tree",
            exit_category: "missing_artifact"
          }
        )
      );
    }
    const projectRoot = root;
    const missions = [];
    const mDir = missionsDir(projectRoot);
    if (fs3.existsSync(mDir)) {
      for (const entry of fs3.readdirSync(mDir)) {
        const full = `${mDir}/${entry}`;
        if (!fs3.statSync(full).isDirectory()) continue;
        const statePath = missionStatePath(projectRoot, entry);
        const state = readJsonFile(statePath);
        missions.push({
          mission_id: entry,
          phase: typeof state?.phase === "string" ? state.phase : null,
          active_tasks: Array.isArray(state?.active_tasks) ? state.active_tasks : []
        });
      }
    }
    emitOk(COMMAND_NAME2, {
      project_root: projectRoot.replace(/\\/g, "/"),
      geas_dir: geasDir(projectRoot).replace(/\\/g, "/"),
      missions
    });
  });
}

