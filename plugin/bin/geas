var fs4 = __toESM(require("fs"));
var StdinError = class extends Error {
  constructor(message) {
    super(message);
    this.code = "invalid_argument";
  }
};
function stripBom(raw) {
  return raw.charCodeAt(0) === 65279 ? raw.slice(1) : raw;
}
function readFileUtf8(filePath) {
  let raw;
  try {
    raw = fs4.readFileSync(filePath, "utf-8");
  } catch (err2) {
    const e = err2;
    throw new StdinError(
      `failed to read --file '${filePath}': ${e.code ?? "unknown"}`
    );
  }
  return stripBom(raw);
}
function readStdinUtf8() {
  if (process.stdin.isTTY === true) {
    throw new StdinError("stdin is an interactive terminal (no content provided)");
  }
  let raw;
  try {
    raw = fs4.readFileSync(0, "utf-8");
  } catch (err2) {
    const e = err2;
    throw new StdinError(`failed to read stdin: ${e.code ?? "unknown"}`);
  }
  return stripBom(raw);
}
function readPayloadJson(filePath) {
  let raw;
  if (filePath !== void 0 && filePath !== "") {
    raw = readFileUtf8(filePath);
  } else {
    raw = readStdinUtf8();
  }
  const trimmed = raw.trim();
  if (trimmed.length === 0) {
    const src = filePath ? `--file '${filePath}'` : "stdin";
    throw new StdinError(`${src} was empty`);
  }
  try {
    return JSON.parse(trimmed);
  } catch (e) {
    const msg = e instanceof Error ? e.message : String(e);
    const src = filePath ? `--file '${filePath}'` : "stdin";
    throw new StdinError(`invalid JSON on ${src}: ${msg}`);
  }
}
function readPayloadText(filePath) {
  let raw;
  if (filePath !== void 0 && filePath !== "") {
    raw = readFileUtf8(filePath);
  } else {
    raw = readStdinUtf8();
  }
  if (raw.length === 0) {
    const src = filePath ? `--file '${filePath}'` : "stdin";
    throw new StdinError(`${src} was empty`);
  }
  return raw;
}

// src/lib/schema.ts
var ajvInstance = null;
var validatorCache = /* @__PURE__ */ new Map();
function getAjv() {
  if (ajvInstance) return ajvInstance;
  const AjvClass = require__().default || require__();
  const addFormatsMod = require_dist();
  const addFormats = addFormatsMod.default || addFormatsMod;
  ajvInstance = new AjvClass({
    allErrors: true,
    strict: false,
    allowUnionTypes: true
  });
  try {
    addFormats(ajvInstance);
  } catch {
  }
  return ajvInstance;
}
function getValidator(name) {
  const cached = validatorCache.get(name);
  if (cached) return cached;
  const schema = SCHEMAS[name];
  if (!schema) {
    throw new Error(
      `Unknown schema: ${name} (available: ${Object.keys(SCHEMAS).join(", ")})`
    );
  }
  const ajv = getAjv();
  const validator = ajv.compile(schema);
  validatorCache.set(name, validator);
  return validator;
}
function validate(name, data) {
  const validator = getValidator(name);
  const ok2 = validator(data);
  return { ok: ok2, errors: ok2 ? null : validator.errors ?? null };
}

