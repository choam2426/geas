function appendAgentNote(geasDir2, agent, text, cwd) {
  const agentsDir = path7.resolve(geasDir2, "memory", "agents");
  ensureDir(agentsDir);
  const filePath = path7.resolve(agentsDir, `${agent}.md`);
  assertContainedIn(filePath, geasDir2);
  let content;
  if (fs8.existsSync(filePath)) {
    content = fs8.readFileSync(filePath, "utf-8");
    const noteLine = `- ${text}`;
    const existingLines = content.split("\n").map((l) => l.trimEnd());
    if (existingLines.includes(noteLine)) {
      return false;
    }
    if (cwd) writeCheckpointPending(filePath, cwd);
    content = content.trimEnd() + "\n" + noteLine + "\n";
  } else {
    if (cwd) writeCheckpointPending(filePath, cwd);
    const header = agent.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");
    content = `# ${header} Memory

- ${text}
`;
  }
  fs8.writeFileSync(filePath, content, "utf-8");
  return true;
}
