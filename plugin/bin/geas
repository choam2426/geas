var fs5 = __toESM(require("fs"));
var EXIT_CODES = {
  schema_validation_failed: 2,
  guard_failed: 3,
  append_only_violation: 5,
  path_collision: 1,
  missing_artifact: 1,
  invalid_argument: 1,
  io_error: 4,
  internal_error: 1
};
function ok(data) {
  return { ok: true, data };
}
function err(code, message, hints) {
  return { ok: false, error: hints !== void 0 ? { code, message, hints } : { code, message } };
}
function emit(envelope) {
  if (envelope.ok) {
    writeOkEnvelope("", envelope.data);
    process.exit(0);
  }
  writeLegacyErrEnvelope(envelope);
  process.exit(EXIT_CODES[envelope.error.code] ?? 1);
}
var SLOT_ACTORS = [
  "decision-maker",
  "orchestrator",
  "design-authority",
  "challenger",
  "implementer",
  "verifier",
  "risk-assessor",
  "operator",
  "communicator"
];
var SPECIAL_ACTORS = ["user", "cli:auto"];
var SLOT_RE = /^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$/;
function isValidActor(value) {
  if (typeof value !== "string" || value.length === 0) return false;
  if (SPECIAL_ACTORS.includes(value)) return true;
  if (SLOT_ACTORS.includes(value)) return true;
  return SLOT_RE.test(value);
}
function nextEntryId(filePath) {
  try {
    if (!fs5.existsSync(filePath)) return 1;
    const content = fs5.readFileSync(filePath, "utf-8");
    if (!content) return 1;
    const lines = content.split("\n").filter((l) => l.length > 0);
    let maxId = 0;
    for (const line of lines) {
      try {
        const parsed = JSON.parse(line);
        if (parsed && typeof parsed.entry_id === "number" && parsed.entry_id > maxId) {
          maxId = parsed.entry_id;
        }
      } catch {
      }
    }
    return maxId + 1;
  } catch {
    return 1;
  }
}
function recordEvent(projectRoot, event) {
  try {
