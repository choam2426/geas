// src/lib/transition-guards.ts
var fs7 = __toESM(require("fs"));
var path6 = __toESM(require("path"));
var REWIND_TRANSITIONS = /* @__PURE__ */ new Set([
  "integrated->implementing",
  "integrated->reviewed",
  "verified->ready",
  "verified->implementing",
  "verified->reviewed"
]);
function isRewind(from, to) {
  return REWIND_TRANSITIONS.has(`${from}->${to}`);
}
function readRecord(geasDir2, missionId, taskId) {
  const recordPath = path6.resolve(
    geasDir2,
    "missions",
    missionId,
    "tasks",
    taskId,
    "record.json"
  );
  return readJsonFile(recordPath);
}
function hasRecordSection(record, section, fieldCheck) {
  if (!record) return false;
  const sec = record[section];
  if (!sec || typeof sec !== "object") return false;
  if (fieldCheck) {
    return sec[fieldCheck.field] === fieldCheck.value;
  }
  return true;
}
function listEvidenceFiles(geasDir2, missionId, taskId) {
  const evidenceDir = path6.resolve(
    geasDir2,
    "missions",
    missionId,
    "tasks",
    taskId,
    "evidence"
  );
  if (!fs7.existsSync(evidenceDir)) return [];
  try {
    return fs7.readdirSync(evidenceDir).filter((f) => f.endsWith(".json"));
  } catch {
    return [];
  }
}
function hasEvidenceWithRole(geasDir2, missionId, taskId, roles) {
  const evidenceDir = path6.resolve(
    geasDir2,
    "missions",
    missionId,
    "tasks",
    taskId,
    "evidence"
  );
  if (!fs7.existsSync(evidenceDir)) return false;
  try {
    const files = fs7.readdirSync(evidenceDir).filter((f) => f.endsWith(".json"));
    for (const file of files) {
      const data = readJsonFile(
        path6.resolve(evidenceDir, file)
      );
      if (data && typeof data.role === "string" && roles.includes(data.role)) {
        return true;
      }
    }
  } catch {
  }
  return false;
}
function guardDraftedToReady(geasDir2, missionId, taskId) {
  const contractPath = path6.resolve(
    geasDir2,
    "missions",
    missionId,
    "tasks",
    taskId,
    "contract.json"
  );
  const task = readJsonFile(contractPath);
  if (!task) {
    return { valid: false, missing_artifacts: [`tasks/${taskId}/contract.json`] };
  }
  const required = [
    "task_kind",
    "risk_level",
    "gate_profile",
    "vote_round_policy",
    "base_snapshot"
  ];
  const missing = [];
  for (const field of required) {
    if (task[field] === void 0 || task[field] === null) {
      missing.push(`contract.json.${field}`);
    }
  }
  const rubric = task.rubric;
  if (!rubric || !Array.isArray(rubric.dimensions) || rubric.dimensions.length === 0) {
    missing.push("contract.json.rubric.dimensions[]");
  }
  return missing.length === 0 ? { valid: true } : { valid: false, missing_artifacts: missing };
}
function guardReadyToImplementing(geasDir2, missionId, taskId) {
  const record = readRecord(geasDir2, missionId, taskId);
  if (!hasRecordSection(record, "implementation_contract", { field: "status", value: "approved" })) {
    const sec = record?.["implementation_contract"];
    if (!sec) {
      return {
        valid: false,
        missing_artifacts: ["record.json:implementation_contract section"]
      };
    }
    return {
      valid: false,
      missing_artifacts: [
        `record.json:implementation_contract.status must be "approved" (got "${sec.status}")`
      ]
    };
  }
  return { valid: true };
}
function guardImplementingToReviewed(geasDir2, missionId, taskId) {
  const missing = [];
  const record = readRecord(geasDir2, missionId, taskId);
  if (!hasRecordSection(record, "self_check")) {
    missing.push("record.json:self_check section");
  }
  if (!hasEvidenceWithRole(geasDir2, missionId, taskId, ["implementer"])) {
    const evidenceFiles = listEvidenceFiles(geasDir2, missionId, taskId);
    if (evidenceFiles.length === 0) {
      missing.push("evidence/ (no files)");
    } else {
      missing.push("evidence/ (no file with role=implementer)");
    }
  }
  return missing.length === 0 ? { valid: true } : { valid: false, missing_artifacts: missing };
}
function guardReviewedToIntegrated(geasDir2, missionId, taskId) {
  const missing = [];
  const record = readRecord(geasDir2, missionId, taskId);
  if (!hasRecordSection(record, "gate_result", { field: "verdict", value: "pass" })) {
    const sec = record?.["gate_result"];
    if (!sec) {
      missing.push("record.json:gate_result section");
    } else {
      missing.push(
        `record.json:gate_result.verdict must be "pass" (got "${sec.verdict}")`
      );
    }
  }
  if (!hasEvidenceWithRole(geasDir2, missionId, taskId, ["reviewer", "tester"])) {
    missing.push("evidence/ (no file with role=reviewer or role=tester)");
  }
  return missing.length === 0 ? { valid: true } : { valid: false, missing_artifacts: missing };
}
function guardIntegratedToVerified(_geasDir, _missionId, _taskId) {
  return { valid: true };
}
function guardVerifiedToPassed(geasDir2, missionId, taskId) {
  const missing = [];
  const record = readRecord(geasDir2, missionId, taskId);
  if (!hasRecordSection(record, "verdict", { field: "verdict", value: "pass" })) {
    const sec = record?.["verdict"];
    if (!sec) {
      missing.push("record.json:verdict section");
    } else {
      missing.push(
        `record.json:verdict.verdict must be "pass" (got "${sec.verdict}")`
      );
    }
  }
  if (!hasRecordSection(record, "gate_result", { field: "verdict", value: "pass" })) {
    const sec = record?.["gate_result"];
    if (!sec) {
      missing.push("record.json:gate_result section");
    } else {
      missing.push(
        `record.json:gate_result.verdict must be "pass" (got "${sec.verdict}")`
      );
    }
  }
  if (!hasRecordSection(record, "closure")) {
    missing.push("record.json:closure section");
  } else {
    const closure = record["closure"];
    const reviews = closure.reviews;
    if (!Array.isArray(reviews) || reviews.length === 0) {
      missing.push("record.json:closure.reviews must have at least 1 review");
    }
    if (Array.isArray(reviews)) {
      for (const review of reviews) {
        const reviewObj = review;
        if (reviewObj.status === "blocked") {
          missing.push(`record.json:closure.reviews contains a review with status "blocked" (from ${reviewObj.reviewer_type || "unknown"})`);
        }
      }
    }
  }
  if (!hasRecordSection(record, "retrospective")) {
    missing.push("record.json:retrospective section");
  }
  const contractPath = path6.resolve(
    geasDir2,
    "missions",
    missionId,
    "tasks",
    taskId,
    "contract.json"
  );
  const contract = readJsonFile(contractPath);
  const routing = contract?.routing;
  const requiredReviewers = routing?.required_reviewer_types;
  if (Array.isArray(requiredReviewers) && requiredReviewers.length > 0) {
    for (const reviewerType of requiredReviewers) {
      const evidenceDir = path6.resolve(
        geasDir2,
        "missions",
        missionId,
        "tasks",
        taskId,
        "evidence"
      );
      if (fs7.existsSync(evidenceDir)) {
        const files = fs7.readdirSync(evidenceDir).filter((f) => f.endsWith(".json"));
        const hasEvidence = files.some((f) => {
          const name = f.replace(".json", "");
          return name === reviewerType || name.replace(/_/g, "-") === reviewerType.replace(/_/g, "-") || name.startsWith(reviewerType.replace(/_/g, "-"));
        });
        if (!hasEvidence) {
          missing.push(`evidence/ missing for required reviewer type "${reviewerType}"`);
        }
      } else {
        missing.push(`evidence/ directory does not exist (required reviewer "${reviewerType}" not covered)`);
      }
    }
  }
  const riskLevel = contract?.risk_level;
  const requiresChallenge = ["high", "critical"].includes(riskLevel ?? "");
  if (requiresChallenge) {
    if (!hasRecordSection(record, "challenge_review")) {
      missing.push(
        `record.json:challenge_review section (required for ${riskLevel}-risk task)`
      );
    } else {
      const cr = record["challenge_review"];
      if (cr.blocking === true) {
        missing.push("record.json:challenge_review.blocking is true (must be resolved before passing)");
      }
    }
  }
  return missing.length === 0 ? { valid: true } : { valid: false, missing_artifacts: missing };
}
var GUARDS = {
  "drafted->ready": guardDraftedToReady,
  "ready->implementing": guardReadyToImplementing,
  "implementing->reviewed": guardImplementingToReviewed,
  "reviewed->integrated": guardReviewedToIntegrated,
  "integrated->verified": guardIntegratedToVerified,
  "verified->passed": guardVerifiedToPassed
};
function validateTransition(geasDir2, missionId, taskId, fromStatus, toStatus) {
  if (isRewind(fromStatus, toStatus)) {
    return { valid: true };
  }
  const auxiliary = ["blocked", "escalated", "cancelled"];
  if (auxiliary.includes(toStatus)) {
    return { valid: true };
  }
  if (["blocked", "escalated"].includes(fromStatus) && toStatus === "ready") {
    return { valid: true };
  }
  const key = `${fromStatus}->${toStatus}`;
  const guard = GUARDS[key];
  if (!guard) {
    return { valid: true };
  }
  return guard(geasDir2, missionId, taskId);
}

