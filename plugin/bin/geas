// src/lib/schema.ts
var ajvInstance = null;
var validatorCache = /* @__PURE__ */ new Map();
function getAjv() {
  if (ajvInstance) return ajvInstance;
  const AjvClass = require_ajv().default || require_ajv();
  ajvInstance = new AjvClass({
    allErrors: true,
    strict: false,
    allowUnionTypes: true,
    validateSchema: false
  });
  ajvInstance.addSchema(DEFS_SCHEMA, "_defs.schema.json");
  return ajvInstance;
}
function getValidator(schemaName) {
  const cached = validatorCache.get(schemaName);
  if (cached) return cached;
  const ajv = getAjv();
  const schema = SCHEMAS[schemaName];
  if (!schema) {
    throw new Error(`Schema not found: ${schemaName} (available: ${Object.keys(SCHEMAS).join(", ")})`);
  }
  const validator = ajv.compile(schema);
  validatorCache.set(schemaName, validator);
  return validator;
}
function getSchemaObject(schemaName) {
  return SCHEMAS[schemaName];
}
function validate(schemaName, data) {
  const validator = getValidator(schemaName);
  const valid = validator(data);
  return {
    valid,
    errors: valid ? null : validator.errors ?? null
  };
}

// src/lib/output.ts
function resolvePropertySchema(schema, propertyName) {
  return schema.properties?.[propertyName];
}
function navigateSchema(schema, instancePath) {
  if (!instancePath || instancePath === "") return schema;
  const parts = instancePath.split("/").filter(Boolean);
  let current = schema;
  for (const part of parts) {
    if (current.properties?.[part]) {
      current = current.properties[part];
    } else if (current.items && !isNaN(Number(part))) {
      current = current.items;
    } else {
      return current;
    }
  }
  return current;
}
function extractHints(schemaName, errors) {
  const rawSchema = getSchemaObject(schemaName);
  const topRequired = rawSchema?.required ?? [];
  const hintEntries = [];
  if (!rawSchema) {
    return { required_fields: [], errors: hintEntries };
  }
  for (const err of errors) {
    const e = err;
    if (!e || !e.keyword) continue;
    const entry = {
      path: e.instancePath || "/",
      keyword: e.keyword,
      message: e.message
    };
    switch (e.keyword) {
      case "enum": {
        const node = navigateSchema(rawSchema, e.instancePath);
        const allowedValues = e.params?.allowedValues;
        if (Array.isArray(allowedValues)) {
          entry.allowed_values = allowedValues;
        } else if (node?.enum) {
          entry.allowed_values = node.enum;
        }
        break;
      }
      case "additionalProperties": {
        const containerNode = navigateSchema(rawSchema, e.instancePath);
        if (containerNode?.properties) {
          entry.allowed_properties = Object.keys(containerNode.properties);
        }
        break;
      }
      case "required": {
        const missingProp = e.params?.missingProperty;
        if (missingProp) {
          const containerNode = navigateSchema(rawSchema, e.instancePath);
          const propSchema = resolvePropertySchema(containerNode, missingProp);
          if (propSchema) {
            if (propSchema.type) {
              entry.field_type = propSchema.type;
            }
            if (propSchema.description) {
              entry.field_description = propSchema.description;
            }
          }
        }
        break;
      }
      // Other keywords: include base entry with path and message
      default:
        break;
    }
    hintEntries.push(entry);
  }
  return {
    required_fields: topRequired,
    errors: hintEntries
  };
}
function success(data) {
  process.stdout.write(JSON.stringify(data) + "\n");
  process.exit(0);
}
function validationError(schemaName, errors) {
  const hints = extractHints(schemaName, errors);
  const msg = {
    error: `Validation failed against schema '${schemaName}'`,
    code: "VALIDATION_ERROR",
    schema: schemaName,
    details: errors,
    hints
  };
  process.stderr.write(JSON.stringify(msg) + "\n");
  process.exit(1);
}
function fileError(filePath, operation, cause) {
  const msg = {
    error: `File ${operation} failed: ${cause}`,
    code: "FILE_ERROR",
    path: filePath,
    operation
  };
  process.stderr.write(JSON.stringify(msg) + "\n");
  process.exit(2);
}
function noStdinError(operation, cause) {
  const msg = {
    error: `No JSON on stdin for '${operation}': ${cause}`,
    code: "NO_STDIN",
    operation,
    examples: [
      `heredoc: geas <cmd> <<'JSON'\\n{"key":"value"}\\nJSON`,
      `pipe:    echo '{"key":"value"}' | geas <cmd>`,
      "redir:   geas <cmd> < payload.json"
    ]
  };
  process.stderr.write(JSON.stringify(msg) + "\n");
  process.exit(2);
}
function warn(message) {
  process.stderr.write(`[Geas] WARNING: ${message}
`);
}

// src/lib/fs-atomic.ts
function shouldRunChecks(filePath, options) {
  if (options?.runChecks !== void 0) return options.runChecks;
  const norm2 = filePath.replace(/\\/g, "/");
  return norm2.includes("/.geas/") || norm2.startsWith(".geas/");
}
function ensureDir(dirPath) {
  fs3.mkdirSync(dirPath, { recursive: true });
}
function readJsonFile(filePath) {
  try {
    const content = fs3.readFileSync(filePath, "utf-8");
    return JSON.parse(content);
  } catch (err) {
    const nodeErr = err;
    if (nodeErr.code === "ENOENT") {
      return null;
    }
    if (err instanceof SyntaxError) {
      throw new Error(
        `Failed to parse JSON at ${normalizePath(filePath)}: ${err.message}`
      );
    }
    throw err;
  }
}
function writeJsonFile(filePath, data, options) {
  const shouldCheck = shouldRunChecks(filePath, options);
  const cwd = options?.cwd || process.cwd();
  if (shouldCheck) {
    enrichTimestamp(filePath, data);
    writeCheckpointPending(filePath, cwd);
  }
  ensureDir(path3.dirname(filePath));
  const content = JSON.stringify(data, null, 2) + "\n";
  fs3.writeFileSync(filePath, content, "utf-8");
  if (shouldCheck) {
    const warnings = runPostWriteChecks(filePath, data, cwd);
    for (const w of warnings) {
      warn(w);
    }
  }
}
function appendJsonlFile(filePath, entry) {
  ensureDir(path3.dirname(filePath));
  if (typeof entry === "object" && entry !== null) {
    const e = entry;
    if (!e.timestamp) {
      e.timestamp = (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
    }
  }
  const line = JSON.stringify(entry) + "\n";
  fs3.appendFileSync(filePath, line, "utf-8");
}
function atomicWriteJsonFile(filePath, data, options) {
  const shouldCheck = shouldRunChecks(filePath, options);
  const cwd = options?.cwd || process.cwd();
  if (shouldCheck) {
    enrichTimestamp(filePath, data);
    writeCheckpointPending(filePath, cwd);
  }
  ensureDir(path3.dirname(filePath));
  const content = JSON.stringify(data, null, 2) + "\n";
  const tmpPath = filePath + ".tmp";
  try {
    fs3.writeFileSync(tmpPath, content, "utf-8");
    fs3.renameSync(tmpPath, filePath);
  } catch (err) {
    const nodeErr = err;
    if (nodeErr.code === "EXDEV") {
      fs3.writeFileSync(filePath, content, "utf-8");
      try {
        fs3.unlinkSync(tmpPath);
      } catch {
      }
    } else {
      try {
        fs3.unlinkSync(tmpPath);
      } catch {
      }
      throw err;
    }
  }
  if (shouldCheck) {
    const warnings = runPostWriteChecks(filePath, data, cwd);
    for (const w of warnings) {
      warn(w);
    }
  }
}

// src/lib/cwd.ts
function getCwd(cmd) {
  const opts = cmd.optsWithGlobals();
  return opts.cwd || process.cwd();
}

// src/commands/state.ts
function runJsonPath(geasDir2) {
  return path4.join(geasDir2, "state", "run.json");
}
function registerStateCommands(program2) {
  const cmd = program2.command("state").description("Run state management (run.json, checkpoints)");
  cmd.command("init").description("Bootstrap .geas/ directory structure and initial run.json").action(() => {
    try {
      const cwd = getCwd(cmd);
      const geasDir2 = path4.join(cwd, ".geas");
      const dirs = [
        path4.join(geasDir2, "state"),
        path4.join(geasDir2, "memory", "agents"),
        path4.join(geasDir2, "recovery")
      ];
      for (const d of dirs) {
        ensureDir(d);
      }
      const filePath = runJsonPath(geasDir2);
      if (fs4.existsSync(filePath)) {
        const existing = readJsonFile(filePath);
        success({ action: "skipped", reason: "run.json already exists", data: existing });
        return;
      }
      const now = (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
      const initialState = {
        version: "1.0",
        status: "initialized",
        mission: null,
        phase: null,
        current_task_id: null,
        completed_tasks: [],
        decisions: [],
        created_at: now
      };
      fs4.writeFileSync(filePath, JSON.stringify(initialState, null, 2) + "\n", "utf-8");
      success({ action: "created", path: filePath.replace(/\\/g, "/"), data: initialState });
    } catch (err) {
      const e = err;
      fileError(".geas/state/run.json", "init", e.message);
    }
  });
  cmd.command("read").description("Read current run state").action(() => {
    try {
      const geas = resolveGeasDir(getCwd(cmd));
      const filePath = runJsonPath(geas);
      const data = readJsonFile(filePath);
      if (data === null) {
        fileError(filePath, "read", "run.json not found");
        return;
      }
      success(data);
    } catch (err) {
      const e = err;
      fileError(".geas/state/run.json", "read", e.message);
    }
  });
  cmd.command("update").description("Update a field in run.json atomically").requiredOption("--field <field>", "Field name to update").requiredOption("--value <value>", "New value (JSON-parsed if possible)").action((opts) => {
    try {
      const cwd = getCwd(cmd);
      const geas = resolveGeasDir(cwd);
      const filePath = runJsonPath(geas);
      const data = readJsonFile(filePath);
      if (data === null) {
        fileError(filePath, "read", "run.json not found");
        return;
      }
      let parsedValue;
      try {
        parsedValue = JSON.parse(opts.value);
      } catch {
        parsedValue = opts.value;
      }
      data[opts.field] = parsedValue;
      if (opts.field === "phase" && parsedValue === "complete") {
        data.mission_id = null;
        data.mission = null;
        data.completed_tasks = [];
        data.current_task_id = null;
      }
      atomicWriteJsonFile(filePath, data, { cwd });
      if (opts.field === "phase" && parsedValue === "complete") {
        success({ updated: opts.field, value: parsedValue, auto_cleared: ["mission_id", "mission", "completed_tasks", "current_task_id"] });
      } else {
        success({ updated: opts.field, value: parsedValue });
      }
    } catch (err) {
      const e = err;
      fileError(".geas/state/run.json", "update", e.message);
    }
  });
  const checkpoint = cmd.command("checkpoint").description("Checkpoint management in run.json");
  checkpoint.command("set").description("Set checkpoint in run.json").requiredOption("--step <step>", "Pipeline step name").requiredOption("--agent <agent>", "Agent currently in flight").option("--retry-count <n>", "Retry count", "0").option("--batch <tasks>", "Parallel batch task IDs (comma-separated)").action(
    (opts) => {
      try {
        const cwd = getCwd(cmd);
        const geas = resolveGeasDir(cwd);
        const filePath = runJsonPath(geas);
        const data = readJsonFile(filePath);
        if (data === null) {
          fileError(filePath, "read", "run.json not found");
          return;
        }
        const existing = data.checkpoint || {};
        const now = (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
        data.checkpoint = {
          ...existing,
          pipeline_step: opts.step,
          agent_in_flight: opts.agent,
          retry_count: parseInt(opts.retryCount, 10) || 0,
          last_updated: now,
          checkpoint_phase: "committed",
          ...opts.batch !== void 0 ? {
            parallel_batch: opts.batch.split(",").map((s) => s.trim()).filter(Boolean)
          } : {}
        };
        atomicWriteJsonFile(filePath, data, { cwd });
        success({ checkpoint: data.checkpoint });
      } catch (err) {
        const e = err;
        fileError(".geas/state/run.json", "checkpoint set", e.message);
      }
    }
  );
  checkpoint.command("clear").description("Clear checkpoint in run.json").action(() => {
    try {
      const cwd = getCwd(cmd);
      const geas = resolveGeasDir(cwd);
      const filePath = runJsonPath(geas);
      const data = readJsonFile(filePath);
      if (data === null) {
        fileError(filePath, "read", "run.json not found");
        return;
      }
      data.checkpoint = {
        pipeline_step: null,
        agent_in_flight: null,
        pending_evidence: [],
        retry_count: 0,
        parallel_batch: null,
        completed_in_batch: [],
        remaining_steps: [],
        last_updated: (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z"),
        checkpoint_phase: "committed"
      };
      atomicWriteJsonFile(filePath, data, { cwd });
      success({ checkpoint: data.checkpoint });
    } catch (err) {
      const e = err;
      fileError(".geas/state/run.json", "checkpoint clear", e.message);
    }
  });
  cmd.command("session-update").description(
    "Write session-latest.md (reads JSON from stdin with phase, task, step info)"
  ).option("--phase <phase>", "Current phase").option("--task <task>", "Current task ID").option("--step <step>", "Current pipeline step").option("--summary <text>", "Summary text").action(
    (opts) => {
      try {
        const geas = resolveGeasDir(getCwd(cmd));
        const sessionPath = path4.join(geas, "state", "session-latest.md");
        const now = (/* @__PURE__ */ new Date()).toISOString().replace(/\.\d{3}Z$/, "Z");
        const lines = [
          "# Session Latest",
          "",
          `**Updated**: ${now}`
        ];
        if (opts.phase) {
          lines.push(`**Phase**: ${opts.phase}`);
        }
        if (opts.task) {
          lines.push(`**Current Task**: ${opts.task}`);
        }
        if (opts.step) {
          lines.push(`**Pipeline Step**: ${opts.step}`);
        }
        if (opts.summary) {
          lines.push("", "## Summary", "", opts.summary);
        }
        lines.push("");
        ensureDir(path4.dirname(sessionPath));
        fs4.writeFileSync(sessionPath, lines.join("\n"), "utf-8");
        success({
          written: "session-latest.md",
          path: sessionPath.replace(/\\/g, "/")
        });
      } catch (err) {
        const e = err;
        fileError(
          ".geas/state/session-latest.md",
          "write",
          e.message
        );
      }
    }
  );
}

