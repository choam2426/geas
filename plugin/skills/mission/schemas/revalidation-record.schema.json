{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RevalidationRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version", "artifact_type", "artifact_id", "producer_type", "created_at",
    "task_id", "base_snapshot", "tip_commit", "scope_overlap",
    "overlapping_paths", "classification", "action_taken"
  ],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "artifact_type": { "type": "string", "const": "revalidation_record" },
    "artifact_id": { "type": "string" },
    "producer_type": { "$ref": "_defs.schema.json#/$defs/agentType" },
    "created_at": { "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp" },
    "task_id": { "type": "string" },
    "base_snapshot": { "type": "string" },
    "tip_commit": { "type": "string" },
    "scope_overlap": { "type": "boolean" },
    "overlapping_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "classification": {
      "type": "string",
      "enum": ["clean_sync", "review_sync", "replan_required", "blocking_conflict"]
    },
    "action_taken": { "type": "string", "minLength": 1 }
  }
}
