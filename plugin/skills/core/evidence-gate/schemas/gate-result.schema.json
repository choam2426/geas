{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GateResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "created_at",
    "task_id",
    "gate_profile",
    "verdict",
    "tier_results",
    "rubric_scores",
    "blocking_dimensions",
    "retry_budget_before",
    "retry_budget_after"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "gate_result"
    },
    "artifact_id": {
      "type": "string"
    },
    "producer_type": {
      "$ref": "_defs.schema.json#/$defs/agentType"
    },
    "created_at": {
      "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
    },
    "task_id": {
      "type": "string"
    },
    "gate_profile": {
      "type": "string",
      "enum": ["code_change", "artifact_only", "closure_ready"]
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "block", "error"]
    },
    "tier_results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier_0", "tier_1", "tier_2"],
      "properties": {
        "tier_0": {
          "$ref": "#/$defs/tierResult"
        },
        "tier_1": {
          "$ref": "#/$defs/tierResult"
        },
        "tier_2": {
          "$ref": "#/$defs/tierResult"
        }
      }
    },
    "rubric_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "score", "threshold", "passed"],
        "properties": {
          "dimension": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "threshold": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "passed": {
            "type": "boolean"
          }
        }
      }
    },
    "blocking_dimensions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stub_count": {
      "type": "integer",
      "minimum": 0
    },
    "stub_cap": {
      "type": "integer",
      "minimum": 0
    },
    "retry_budget_before": {
      "type": "integer",
      "minimum": 0
    },
    "retry_budget_after": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "tierResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "details"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "block", "error", "skipped"]
        },
        "details": {
          "type": "string"
        }
      }
    }
  }
}
