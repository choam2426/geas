{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GEAS Memory Review",
  "type": "object",
  "properties": {
    "meta": {
      "$ref": "_defs.schema.json#/$defs/commonMeta"
    },
    "memory_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_type": {
      "$ref": "_defs.schema.json#/$defs/agentType"
    },
    "decision": {
      "type": "string",
      "enum": [
        "promote_provisional",
        "promote_stable",
        "promote_canonical",
        "keep",
        "weaken",
        "supersede",
        "reject",
        "archive"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "required_followup": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "meta",
    "memory_id",
    "reviewer_type",
    "decision",
    "rationale",
    "required_followup",
    "supersedes"
  ],
  "additionalProperties": false
}