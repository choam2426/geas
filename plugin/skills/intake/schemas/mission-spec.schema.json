{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mission Spec",
  "description": "Per-mission specification produced by the intake gate. Each mission gets its own spec file.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "artifact_type": {
      "type": "string",
      "const": "mission_spec"
    },
    "artifact_id": {
      "type": "string",
      "description": "e.g., mission-20260407-x7Kq9mPv"
    },
    "producer_type": {
      "type": "string",
      "description": "Agent type that created this spec"
    },
    "mission_id": {
      "type": "string",
      "pattern": "^mission-([0-9]{3}|[0-9]{8}-[a-zA-Z0-9]{8})$",
      "description": "Mission ID in format mission-{YYYYMMDD}-{8char} (e.g., mission-20260407-x7Kq9mPv)"
    },
    "mission": {
      "type": "string",
      "description": "Refined, unambiguous mission statement"
    },
    "domain_profile": {
      "type": "string",
      "description": "Active domain profile (e.g., software, research)"
    },
    "mode": {
      "type": "string",
      "enum": ["lightweight", "standard", "full_depth"],
      "description": "Mission operating mode — determines rigor level"
    },
    "done_when": {
      "type": "string",
      "description": "One-sentence success definition — what must be true for this mission to be complete"
    },
    "target_user": {
      "type": "string",
      "description": "Primary user persona or audience"
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Technical or business constraints"
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Assumptions surfaced during intake that the user confirmed"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3,
      "description": "Measurable criteria that define completion. Minimum 3 required."
    },
    "scope_in": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Features and capabilities explicitly included"
    },
    "scope_out": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Features and capabilities explicitly excluded"
    },
    "risk_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Initial risk observations identified during intake"
    },
    "affected_surfaces": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Areas, paths, or systems expected to be touched"
    },
    "ambiguity_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Remaining ambiguities acknowledged but deferred (with rationale)"
    },
    "source": {
      "type": "string",
      "enum": ["full_intake", "quick_intake", "existing_project"],
      "description": "How this spec was created"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the spec was frozen"
    }
  },
  "required": ["version", "artifact_type", "mission_id", "mission", "domain_profile", "mode", "done_when", "acceptance_criteria", "scope_in", "scope_out", "created_at"]
}
