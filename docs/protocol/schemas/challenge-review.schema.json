{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChallengeReview",
  "description": "Critical reviewer pre-ship challenge. Mandatory for high/critical risk tasks; discretionary otherwise. The reviewer must raise at least 1 substantive concern.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "task_id",
    "reviewer_type",
    "concerns",
    "blocking",
    "created_at"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "challenge_review"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "producer_type": {
      "type": "string",
      "const": "challenger"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_type": {
      "type": "string",
      "const": "challenger"
    },
    "concerns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "description"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocking", "non_blocking"],
            "description": "blocking = must be resolved or acknowledged via readiness_round before final verdict"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "structural_risk",
              "hidden_assumption",
              "excessive_complexity",
              "missing_edge_case",
              "technical_debt",
              "security_concern",
              "other"
            ]
          }
        }
      },
      "description": "At least 1 concern required (substantive challenge obligation)"
    },
    "blocking": {
      "type": "boolean",
      "description": "true if ANY concern has severity = blocking"
    },
    "summary": {
      "type": "string",
      "description": "Brief overall assessment from the critical reviewer"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "memory_suggestions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Knowledge the Challenger recommends persisting for future critical review invocations"
    }
  }
}
