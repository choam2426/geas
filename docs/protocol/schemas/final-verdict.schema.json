{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinalVerdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "created_at",
    "task_id",
    "verdict",
    "rationale",
    "closure_packet_ref"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "final_verdict"
    },
    "artifact_id": {
      "type": "string"
    },
    "producer_type": {
      "type": "string",
      "const": "product_authority"
    },
    "created_at": {
      "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
    },
    "task_id": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "iterate", "escalate"]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "rewind_target": {
      "type": "string",
      "enum": ["ready", "implementing", "reviewed"]
    },
    "iterate_count": {
      "type": "integer",
      "minimum": 1
    },
    "escalation_reason": {
      "type": "string",
      "minLength": 1
    },
    "closure_packet_ref": {
      "type": "string"
    }
  }
}
