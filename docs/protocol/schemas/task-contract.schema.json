{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "title",
    "goal",
    "task_kind",
    "risk_level",
    "gate_profile",
    "vote_round_policy",
    "acceptance_criteria",
    "eval_commands",
    "rubric",
    "retry_budget",
    "scope",
    "routing",
    "base_snapshot",
    "status"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "task_kind": {
      "type": "string",
      "enum": [
        "implementation",
        "documentation",
        "configuration",
        "design",
        "review",
        "analysis",
        "delivery"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high",
        "critical"
      ]
    },
    "gate_profile": {
      "type": "string",
      "enum": [
        "implementation_change",
        "artifact_only",
        "closure_ready"
      ]
    },
    "vote_round_policy": {
      "type": "string",
      "enum": [
        "never",
        "auto",
        "always"
      ]
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "eval_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rubric": {
      "type": "object",
      "properties": {
        "dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "threshold"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "threshold": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              }
            }
          },
          "minItems": 1
        }
      },
      "required": [
        "dimensions"
      ],
      "additionalProperties": false
    },
    "retry_budget": {
      "type": "integer",
      "minimum": 0
    },
    "scope": {
      "type": "object",
      "properties": {
        "surfaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "surfaces"
      ],
      "additionalProperties": false
    },
    "routing": {
      "type": "object",
      "properties": {
        "primary_worker_slot": {
          "$ref": "_defs.schema.json#/$defs/specialistSlot"
        },
        "primary_worker_type": {
          "$ref": "_defs.schema.json#/$defs/agentTypeId"
        },
        "required_reviewer_slots": {
          "type": "array",
          "items": {
            "$ref": "_defs.schema.json#/$defs/anySlot"
          },
          "minItems": 1
        },
        "required_reviewer_types": {
          "type": "array",
          "items": {
            "$ref": "_defs.schema.json#/$defs/agentTypeId"
          },
          "minItems": 1
        }
      },
      "required": [
        "primary_worker_slot",
        "required_reviewer_slots"
      ],
      "additionalProperties": false
    },
    "base_snapshot": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Task IDs that must be passed before this task can start"
    },
    "status": {
      "type": "string",
      "enum": [
        "drafted",
        "ready",
        "implementing",
        "reviewed",
        "integrated",
        "verified",
        "passed",
        "blocked",
        "escalated",
        "cancelled"
      ]
    }
  }
}
