{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "created_at",
    "task_id",
    "title",
    "goal",
    "task_kind",
    "risk_level",
    "gate_profile",
    "vote_round_policy",
    "acceptance_criteria",
    "eval_commands",
    "rubric",
    "retry_budget",
    "scope",
    "routing",
    "base_snapshot",
    "status"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "task_contract"
    },
    "artifact_id": {
      "type": "string"
    },
    "producer_type": {
      "$ref": "_defs.schema.json#/$defs/agentType"
    },
    "created_at": {
      "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
    },
    "task_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "task_kind": {
      "type": "string",
      "enum": ["implementation", "documentation", "configuration", "design", "review", "analysis", "delivery"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "normal", "high", "critical"]
    },
    "gate_profile": {
      "type": "string",
      "enum": ["implementation_change", "artifact_only", "closure_ready"]
    },
    "vote_round_policy": {
      "type": "string",
      "enum": ["never", "auto", "always"]
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "eval_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rubric": {
      "type": "object",
      "properties": {
        "dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "threshold"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "threshold": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              }
            }
          },
          "minItems": 1
        }
      },
      "required": ["dimensions"],
      "additionalProperties": false
    },
    "retry_budget": {
      "type": "integer",
      "minimum": 0
    },
    "scope": {
      "type": "object",
      "properties": {
        "surfaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["surfaces"],
      "additionalProperties": false
    },
    "routing": {
      "type": "object",
      "properties": {
        "primary_worker_type": {
          "$ref": "_defs.schema.json#/$defs/agentType"
        },
        "required_reviewer_types": {
          "type": "array",
          "items": {
            "$ref": "_defs.schema.json#/$defs/agentType"
          },
          "minItems": 1
        }
      },
      "required": ["primary_worker_type", "required_reviewer_types"],
      "additionalProperties": false
    },
    "base_snapshot": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "drafted",
        "ready",
        "implementing",
        "reviewed",
        "integrated",
        "verified",
        "passed",
        "blocked",
        "escalated",
        "cancelled"
      ]
    }
  }
}
