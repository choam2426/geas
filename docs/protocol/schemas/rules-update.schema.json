{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RulesUpdate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "reason",
    "evidence_refs",
    "applies_to"
  ],
  "properties": {
    "producer_type": {
      "type": "string",
      "enum": [
        "design-authority",
        "product-authority",
        "qa-engineer",
        "security-engineer"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "none",
        "proposed",
        "approved",
        "rejected",
        "superseded"
      ]
    },
    "affected_rule_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
