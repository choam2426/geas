{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GEAS Memory Entry",
  "type": "object",
  "properties": {
    "meta": {
      "$ref": "_defs.schema.json#/$defs/commonMeta"
    },
    "memory_id": {
      "type": "string",
      "minLength": 1
    },
    "memory_type": {
      "$ref": "_defs.schema.json#/$defs/memoryType"
    },
    "state": {
      "$ref": "_defs.schema.json#/$defs/memoryState"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "$ref": "_defs.schema.json#/$defs/memoryScope"
    },
    "evidence_refs": {
      "$ref": "_defs.schema.json#/$defs/nonEmptyStringArray"
    },
    "signals": {
      "$ref": "_defs.schema.json#/$defs/memorySignals"
    },
    "review_after": {
      "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "superseded_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "body": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "meta",
    "memory_id",
    "memory_type",
    "state",
    "title",
    "summary",
    "scope",
    "evidence_refs",
    "signals",
    "review_after",
    "supersedes",
    "superseded_by",
    "tags",
    "body"
  ],
  "additionalProperties": false
}