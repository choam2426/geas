{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GEAS Memory Candidate",
  "type": "object",
  "properties": {
    "meta": {
      "$ref": "_defs.schema.json#/$defs/commonMeta"
    },
    "memory_id": {
      "type": "string",
      "minLength": 1
    },
    "memory_type": {
      "$ref": "_defs.schema.json#/$defs/memoryType"
    },
    "state": {
      "const": "candidate"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "$ref": "_defs.schema.json#/$defs/memoryScope"
    },
    "evidence_refs": {
      "$ref": "_defs.schema.json#/$defs/nonEmptyStringArray"
    },
    "signals": {
      "$ref": "_defs.schema.json#/$defs/memorySignals"
    },
    "candidate_reason": {
      "type": "string",
      "minLength": 1
    },
    "source_artifacts": {
      "$ref": "_defs.schema.json#/$defs/nonEmptyStringArray"
    }
  },
  "required": [
    "meta",
    "memory_id",
    "memory_type",
    "state",
    "title",
    "summary",
    "scope",
    "evidence_refs",
    "signals",
    "candidate_reason",
    "source_artifacts"
  ],
  "additionalProperties": false
}