{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence.schema.json",
  "title": "GEAS Agent Evidence",
  "description": "Evidence file produced by an agent. Role-based required fields ensure each agent type provides appropriate detail.",
  "type": "object",
  "properties": {
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": [
        "implementer",
        "reviewer",
        "tester",
        "authority"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "revision_ref": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approved",
        "changes_requested",
        "blocked",
        "pass",
        "iterate",
        "escalate"
      ]
    },
    "concerns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocking": {
      "type": "boolean"
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "criteria_results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          },
          "details": {
            "type": "string"
          }
        },
        "required": [
          "criterion",
          "passed"
        ]
      }
    },
    "rubric_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dimension": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          },
          "rationale": {
            "type": "string"
          }
        },
        "required": [
          "dimension",
          "score"
        ]
      }
    }
  },
  "required": [
    "agent",
    "task_id",
    "role",
    "summary"
  ],
  "additionalProperties": true
}
