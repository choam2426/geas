{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecialistReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "created_at",
    "task_id",
    "reviewer_type",
    "status",
    "summary",
    "blocking_concerns"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "specialist_review"
    },
    "artifact_id": {
      "type": "string"
    },
    "producer_type": {
      "$ref": "_defs.schema.json#/$defs/agentType"
    },
    "created_at": {
      "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
    },
    "task_id": {
      "type": "string"
    },
    "reviewer_type": {
      "$ref": "_defs.schema.json#/$defs/agentType"
    },
    "status": {
      "type": "string",
      "enum": ["approved", "changes_requested", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blocking_concerns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["concern", "severity", "resolved"],
        "properties": {
          "concern": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["minor", "major"]
          },
          "resolved": {
            "type": "boolean"
          }
        }
      }
    },
    "rubric_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "score", "rationale"],
        "properties": {
          "dimension": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "memory_suggestions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Knowledge the specialist recommends persisting for future invocations of this specialist type"
    }
  }
}
