{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "record.schema.json",
  "title": "GEAS Task Execution Record",
  "description": "Single file accumulating all pipeline step outputs for a task. Sections are added incrementally as the pipeline progresses.",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "implementation_contract": {
      "type": "object",
      "properties": {
        "worker": {
          "type": "string",
          "minLength": 1
        },
        "planned_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "edge_cases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "demo_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "in_review",
            "approved",
            "revision_requested"
          ]
        }
      },
      "required": [
        "planned_actions",
        "non_goals",
        "status"
      ],
      "additionalProperties": true
    },
    "self_check": {
      "type": "object",
      "properties": {
        "confidence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "known_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unverified_cases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "confidence",
        "summary",
        "known_risks",
        "unverified_cases"
      ],
      "additionalProperties": true
    },
    "gate_result": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "block",
            "error"
          ]
        }
      },
      "required": [
        "verdict"
      ],
      "additionalProperties": true
    },
    "challenge_review": {
      "type": "object",
      "properties": {
        "concerns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "concerns",
        "blocking"
      ],
      "additionalProperties": true
    },
    "verdict": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "iterate",
            "escalate"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "rewind_target": {
          "type": "string",
          "enum": [
            "ready",
            "implementing",
            "reviewed"
          ]
        }
      },
      "required": [
        "verdict",
        "rationale"
      ],
      "additionalProperties": true
    },
    "closure": {
      "type": "object",
      "properties": {
        "task_summary": {
          "type": "string"
        },
        "change_summary": {
          "type": "string",
          "minLength": 1
        },
        "reviews": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reviewer_type": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "approved",
                  "changes_requested",
                  "blocked"
                ]
              },
              "summary": {
                "type": "string"
              }
            }
          }
        },
        "open_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "debt_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "change_summary",
        "reviews",
        "open_risks",
        "debt_items"
      ],
      "additionalProperties": true
    },
    "retrospective": {
      "type": "object",
      "properties": {
        "what_went_well": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "what_broke": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "what_was_surprising": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rule_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "memory_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "debt_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_time_guidance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "what_went_well",
        "what_broke"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "task_id"
  ],
  "additionalProperties": false
}
