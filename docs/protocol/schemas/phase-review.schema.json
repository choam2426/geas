{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PhaseReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_phase",
    "status",
    "summary"
  ],
  "properties": {
    "mission_phase": {
      "type": "string",
      "enum": [
        "specifying",
        "building",
        "polishing",
        "evolving"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ready_to_enter",
        "ready_to_exit",
        "blocked",
        "escalated"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "next_phase": {
      "type": "string",
      "enum": [
        "specifying",
        "building",
        "polishing",
        "evolving",
        "complete"
      ],
      "description": "The phase to transition into (when status is ready_to_exit)"
    }
  },
  "if": {
    "properties": {
      "status": {
        "const": "ready_to_exit"
      }
    },
    "required": [
      "status"
    ]
  },
  "then": {
    "required": [
      "next_phase"
    ]
  }
}
