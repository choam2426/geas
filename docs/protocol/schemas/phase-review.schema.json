{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PhaseReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "mission_phase",
    "status",
    "summary",
    "created_at"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "phase_review"
    },
    "artifact_id": {
      "type": "string"
    },
    "producer_type": {
      "type": "string",
      "enum": [
        "orchestration_authority",
        "product_authority",
        "process_lead"
      ]
    },
    "mission_phase": {
      "type": "string",
      "enum": [
        "specifying",
        "building",
        "polishing",
        "evolving"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ready_to_enter",
        "ready_to_exit",
        "blocked",
        "escalated"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "gate_criteria_met": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "List of phase gate criteria that have been satisfied"
    },
    "gate_criteria_unmet": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "List of phase gate criteria that remain unsatisfied"
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Known risks or concerns for the upcoming phase"
    },
    "next_phase": {
      "type": "string",
      "enum": [
        "specifying",
        "building",
        "polishing",
        "evolving"
      ],
      "description": "The phase to transition into (when status is ready_to_exit)"
    },
    "created_at": {
      "type": "string"
    }
  }
}