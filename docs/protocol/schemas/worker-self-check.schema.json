{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkerSelfCheck",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "task_id",
    "known_risks",
    "untested_paths",
    "possible_stubs",
    "what_to_test_next",
    "confidence",
    "summary",
    "created_at"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "worker_self_check"
    },
    "artifact_id": {
      "type": "string"
    },
    "producer_type": {
      "type": "string",
      "enum": [
        "frontend_engineer",
        "backend_engineer",
        "devops_engineer",
        "technical_writer"
      ]
    },
    "task_id": {
      "type": "string"
    },
    "known_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "untested_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "possible_stubs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "what_to_test_next": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Confidence level: 1=very_low, 2=low, 3=medium, 4=high, 5=very_high"
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "memory_suggestions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Knowledge the worker recommends persisting for future invocations of this worker type"
    }
  }
}