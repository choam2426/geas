{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DebtRegister",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact_type",
    "artifact_id",
    "producer_type",
    "scope",
    "items",
    "created_at"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "debt_register"
    },
    "artifact_id": {
      "type": "string"
    },
    "producer_type": {
      "type": "string",
      "enum": [
        "process_lead",
        "architecture_authority",
        "product_authority"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "task",
        "phase",
        "mission"
      ]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "debt_id",
          "severity",
          "kind",
          "title",
          "description",
          "status"
        ],
        "properties": {
          "debt_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "kind": {
            "type": "string",
            "enum": [
              "code_quality",
              "architecture",
              "security",
              "docs",
              "ops",
              "test_gap",
              "product_gap"
            ]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "introduced_by_task_id": {
            "type": "string"
          },
          "owner_type": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "accepted",
              "scheduled",
              "resolved",
              "dropped"
            ]
          },
          "target_phase": {
            "type": "string",
            "enum": [
              "polish",
              "evolution",
              "future"
            ]
          }
        }
      }
    },
    "rollup_by_severity": {
      "type": "object",
      "properties": {
        "low": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "critical": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "rollup_by_kind": {
      "type": "object",
      "properties": {
        "code_quality": { "type": "integer", "minimum": 0 },
        "architecture": { "type": "integer", "minimum": 0 },
        "security": { "type": "integer", "minimum": 0 },
        "docs": { "type": "integer", "minimum": 0 },
        "ops": { "type": "integer", "minimum": 0 },
        "test_gap": { "type": "integer", "minimum": 0 },
        "product_gap": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string"
    }
  }
}