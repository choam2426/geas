{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Geas Deliberation Record",
  "description": "Structured multi-party judgment over a proposal. Used at both task level and mission level; level is encoded in the 'level' field.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "level",
    "mission_id",
    "proposal_summary",
    "votes",
    "result",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "level": {
      "type": "string",
      "enum": [
        "mission",
        "task"
      ]
    },
    "mission_id": {
      "type": "string",
      "pattern": "^mission-[0-9]{8}-[a-zA-Z0-9]{8}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]{3}$",
      "description": "Task identifier within the mission. Required when level is 'task'."
    },
    "proposal_summary": {
      "type": "string",
      "minLength": 1,
      "description": "Short summary of the question under deliberation."
    },
    "votes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "voter",
          "vote",
          "rationale"
        ],
        "properties": {
          "voter": {
            "type": "string",
            "description": "Agent type of the voter."
          },
          "vote": {
            "type": "string",
            "enum": [
              "agree",
              "disagree",
              "escalate"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "agree",
        "disagree",
        "escalate",
        "inconclusive"
      ],
      "description": "Outcome of the deliberation. 'inconclusive' means the deliberation did not produce a valid judgment (e.g. insufficient participants)."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "if": {
    "properties": {
      "level": {
        "const": "task"
      }
    },
    "required": [
      "level"
    ]
  },
  "then": {
    "required": [
      "task_id"
    ]
  }
}
