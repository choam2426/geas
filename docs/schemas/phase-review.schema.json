{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Geas Phase Review",
  "description": "Mission-level phase gate record describing whether a phase may be entered, exited, blocked, or escalated.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_phase",
    "status",
    "summary"
  ],
  "properties": {
    "mission_phase": {
      "type": "string",
      "enum": [
        "specifying",
        "building",
        "polishing",
        "consolidating"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ready_to_enter",
        "ready_to_exit",
        "blocked",
        "escalated"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "next_phase": {
      "type": "string",
      "enum": [
        "specifying",
        "building",
        "polishing",
        "consolidating",
        "complete"
      ],
      "description": "The next mission phase to enter when status is ready_to_exit."
    }
  },
  "if": {
    "properties": {
      "status": {
        "const": "ready_to_exit"
      }
    },
    "required": [
      "status"
    ]
  },
  "then": {
    "required": [
      "next_phase"
    ]
  }
}
