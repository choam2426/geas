{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence-review.schema.json",
  "title": "GEAS Review Evidence",
  "type": "object",
  "properties": {
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_kind": {
      "const": "review"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approved",
        "changes_requested",
        "blocked"
      ]
    },
    "concerns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "memory_suggestions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "revision_ref": {
      "type": "string"
    }
  },
  "required": [
    "agent",
    "task_id",
    "evidence_kind",
    "summary",
    "verdict",
    "concerns"
  ],
  "additionalProperties": true
}
