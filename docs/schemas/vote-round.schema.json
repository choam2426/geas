{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VoteRound",
  "description": "Result of a structured vote round — either a proposal_round (agree/disagree) or a readiness_round (ship/iterate/escalate). Recorded in .geas/missions/{mission_id}/decisions/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "round_type",
    "task_id",
    "participants",
    "votes",
    "result",
    "quorum_met"
  ],
  "properties": {
    "round_type": {
      "type": "string",
      "enum": [
        "proposal_round",
        "readiness_round"
      ]
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Task this vote pertains to"
    },
    "proposal_summary": {
      "type": "string",
      "description": "What is being voted on (proposal_round: the proposal text; readiness_round: the ship-readiness question)"
    },
    "participants": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      },
      "description": "Agent types participating. proposal_round: >= 2 (proposer + reviewer). readiness_round: >= orchestrator + decision-maker + 1 specialist."
    },
    "votes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "voter",
          "vote",
          "rationale"
        ],
        "properties": {
          "voter": {
            "type": "string",
            "description": "Agent type of the voter"
          },
          "vote": {
            "type": "string",
            "enum": [
              "agree",
              "disagree",
              "ship",
              "iterate",
              "escalate"
            ],
            "description": "proposal_round: agree|disagree. readiness_round: ship|iterate|escalate."
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "minor",
              "major",
              "critical"
            ],
            "description": "Required when vote is disagree, iterate, or escalate"
          }
        }
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "agree",
        "disagree",
        "ship",
        "iterate",
        "escalate",
        "inconclusive"
      ],
      "description": "Outcome. 'inconclusive' if quorum was not met."
    },
    "quorum_met": {
      "type": "boolean"
    },
    "quorum_failure_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Consecutive quorum failures. 2 consecutive failures = task escalated."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
    }
  }
}
