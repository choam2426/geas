{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence-verification.schema.json",
  "title": "GEAS Verification Evidence",
  "type": "object",
  "properties": {
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_kind": {
      "const": "verification"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approved",
        "changes_requested",
        "blocked"
      ]
    },
    "criteria_results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          },
          "details": {
            "type": "string"
          }
        },
        "required": [
          "criterion",
          "passed"
        ]
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "memory_suggestions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "revision_ref": {
      "type": "string"
    }
  },
  "required": [
    "agent",
    "task_id",
    "evidence_kind",
    "summary",
    "verdict",
    "criteria_results"
  ],
  "additionalProperties": true
}
