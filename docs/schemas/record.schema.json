{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "record.schema.json",
  "title": "GEAS Task Record",
  "description": "Current shared task record for structured sections that are still stored together, including gate, closure, verdict, and retrospective inputs.",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "gate_result": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "block",
            "error"
          ]
        },
        "tier_results": {
          "type": "object",
          "properties": {
            "tier_0": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string"
                },
                "details": {
                  "type": "string"
                }
              },
              "required": [
                "status"
              ]
            },
            "tier_1": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string"
                },
                "details": {
                  "type": "string"
                }
              },
              "required": [
                "status"
              ]
            },
            "tier_2": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string"
                },
                "details": {
                  "type": "string"
                }
              },
              "required": [
                "status"
              ]
            }
          },
          "additionalProperties": false
        },
        "rubric_scores": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dimension": {
                "type": "string"
              },
              "score": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "threshold": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "passed": {
                "type": "boolean"
              }
            },
            "required": [
              "dimension",
              "score",
              "threshold",
              "passed"
            ]
          }
        },
        "blocking_dimensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "verdict"
      ],
      "additionalProperties": true
    },
    "challenge_review": {
      "type": "object",
      "properties": {
        "concerns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "concerns",
        "blocking"
      ],
      "additionalProperties": true
    },
    "verdict": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "approved",
            "changes_requested",
            "escalated"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "rewind_target": {
          "type": "string",
          "enum": [
            "ready",
            "implementing",
            "reviewed"
          ]
        }
      },
      "required": [
        "verdict",
        "rationale"
      ],
      "additionalProperties": true
    },
    "closure": {
      "type": "object",
      "properties": {
        "task_summary": {
          "type": "string"
        },
        "change_summary": {
          "type": "string",
          "minLength": 1
        },
        "reviews": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reviewer_type": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "approved",
                  "changes_requested",
                  "blocked"
                ]
              },
              "summary": {
                "type": "string"
              }
            }
          }
        },
        "open_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "debt_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "change_summary",
        "reviews",
        "open_risks",
        "debt_items"
      ],
      "additionalProperties": true
    },
    "retrospective": {
      "type": "object",
      "properties": {
        "what_went_well": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "what_broke": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "what_was_surprising": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rule_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "memory_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "debt_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_time_guidance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "what_went_well",
        "what_broke"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "task_id"
  ],
  "additionalProperties": false
}
