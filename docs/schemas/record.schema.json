{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "record.schema.json",
  "title": "GEAS Task Record",
  "description": "Current shared task record for structured sections that are still stored together, including retrospective inputs.",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "challenge_review": {
      "type": "object",
      "properties": {
        "concerns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "concerns",
        "blocking"
      ],
      "additionalProperties": true
    },
    "retrospective": {
      "type": "object",
      "properties": {
        "what_went_well": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "what_broke": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "what_was_surprising": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rule_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "memory_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "debt_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_time_guidance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "what_went_well",
        "what_broke"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "task_id"
  ],
  "additionalProperties": false
}
