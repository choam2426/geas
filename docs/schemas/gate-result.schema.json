{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gate-result.schema.json",
  "title": "GEAS Gate Result",
  "description": "Record of a single Evidence Gate run for a task, capturing tier verdicts and the overall gate verdict. Each gate run produces its own artifact so retry history is preserved.",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "gate_run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this gate run within the task. Typically monotonic (e.g. gate-1, gate-2)."
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "block",
        "error"
      ]
    },
    "tier_results": {
      "type": "object",
      "properties": {
        "tier_0": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "details": {
              "type": "string"
            }
          },
          "required": [
            "status"
          ]
        },
        "tier_1": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "details": {
              "type": "string"
            }
          },
          "required": [
            "status"
          ]
        },
        "tier_2": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "details": {
              "type": "string"
            }
          },
          "required": [
            "status"
          ]
        }
      },
      "additionalProperties": false
    },
    "previous_run_ref": {
      "type": "string",
      "description": "Reference to the previous gate run for this task, if this is a retry."
    }
  },
  "required": [
    "task_id",
    "gate_run_id",
    "verdict"
  ],
  "additionalProperties": true
}
