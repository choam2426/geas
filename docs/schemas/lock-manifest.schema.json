{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LockManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "locks"
  ],
  "properties": {
    "locks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "lock_type",
          "task_id",
          "session_id",
          "targets",
          "status",
          "acquired_at"
        ],
        "properties": {
          "lock_type": {
            "type": "string",
            "enum": [
              "path",
              "interface",
              "resource",
              "integration"
            ]
          },
          "task_id": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "held",
              "waiting"
            ]
          },
          "acquired_at": {
            "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
          },
          "wait_start": {
            "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
          }
        }
      }
    }
  }
}
