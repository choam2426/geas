{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GEAS Recovery Packet",
  "description": "Structured recovery assessment describing what was found after interruption and what action is recommended next.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recovery_id",
    "recovery_class",
    "focus_task_id",
    "detected_problem",
    "recommended_action",
    "artifacts_found",
    "artifacts_missing"
  ],
  "properties": {
    "recovery_id": {
      "type": "string",
      "minLength": 1
    },
    "recovery_class": {
      "type": "string",
      "enum": [
        "post_compact_resume",
        "warm_session_resume",
        "interrupted_subagent_resume",
        "dirty_state_recovery",
        "manual_repair_required"
      ]
    },
    "focus_task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "detected_problem": {
      "type": "string",
      "minLength": 1
    },
    "recommended_action": {
      "type": "string",
      "minLength": 1
    },
    "artifacts_found": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts_missing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
