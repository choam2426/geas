{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "self-check.schema.json",
  "title": "GEAS Worker Self-Check",
  "description": "Worker self-check artifact recorded after implementation and before review.",
  "type": "object",
  "properties": {
    "confidence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "known_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unverified_cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "confidence",
    "summary",
    "known_risks",
    "unverified_cases"
  ],
  "additionalProperties": true
}
