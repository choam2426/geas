{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GEAS Run State",
  "description": "Mission runtime state and checkpoint used to resume or repair execution after interruption.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "initialized",
        "in_progress",
        "complete"
      ],
      "description": "Overall session status"
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^mission-([0-9]{3}|[0-9]{8}-[a-zA-Z0-9]{8})$",
      "description": "Mission ID used to locate mission artifacts."
    },
    "mission": {
      "type": [
        "string",
        "null"
      ],
      "description": "Human-readable mission statement copied from the current mission spec."
    },
    "phase": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "specifying",
        "building",
        "polishing",
        "consolidating",
        "complete",
        null
      ],
      "description": "Current phase within the mission"
    },
    "current_task_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "ID of the task currently being executed"
    },
    "completed_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs of tasks that have been resolved"
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs of DecisionRecords created during the session"
    },
    "session_latest_path": {
      "type": [
        "string",
        "null"
      ],
      "default": ".geas/state/session-latest.md",
      "description": "Path to human-readable session summary for post-compact recovery"
    },
    "recovery_class": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "post_compact_resume",
        "warm_session_resume",
        "interrupted_subagent_resume",
        "dirty_state_recovery",
        "manual_repair_required",
        null
      ],
      "description": "Recovery class from last session recovery. Null if clean session."
    },
    "scheduler_state": {
      "type": "string",
      "enum": [
        "active",
        "idle",
        "paused"
      ],
      "default": "active",
      "description": "Implementation-reported execution state for the runtime loop."
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pipeline_step": {
          "type": [
            "string",
            "null"
          ],
          "description": "Current runtime pipeline step name."
        },
        "agent_in_flight": {
          "type": [
            "string",
            "null"
          ],
          "description": "Agent currently spawned and executing"
        },
        "pending_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Evidence files expected from the current agent"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of verify-fix iterations used for the current task"
        },
        "parallel_batch": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "description": "Task IDs being executed in the current parallel batch. Null when running sequentially."
        },
        "completed_in_batch": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Task IDs resolved within the current parallel batch."
        },
        "remaining_steps": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ordered list of pipeline steps still to complete. Pop from front after each step."
        },
        "last_updated": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of last checkpoint update"
        },
        "checkpoint_phase": {
          "type": "string",
          "enum": [
            "pending",
            "committed"
          ],
          "default": "committed",
          "description": "Two-phase checkpoint state. 'pending' during write, 'committed' after."
        }
      },
      "description": "Pipeline checkpoint for session recovery."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "$ref": "_defs.schema.json#/$defs/isoUtcTimestamp"
    }
  }
}
