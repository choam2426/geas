{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mission-verdict.schema.json",
  "title": "GEAS Mission Final Verdict",
  "description": "Final verdict on whether a mission is approved, needs more work, or must be escalated. Produced by Decision Maker at the end of the consolidating phase.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "verdict",
    "rationale"
  ],
  "properties": {
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approved",
        "changes_requested",
        "escalated"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "description": "Reasoning for the verdict, grounded in the referenced artifacts."
    },
    "references": {
      "type": "object",
      "description": "Pointers to artifacts the Decision Maker read when forming the verdict.",
      "additionalProperties": false,
      "properties": {
        "mission_spec": {
          "type": "string"
        },
        "mission_design": {
          "type": "string"
        },
        "last_phase_review": {
          "type": "string"
        },
        "gap_assessment": {
          "type": "string"
        },
        "debt_register": {
          "type": "string"
        },
        "deliberations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "carry_forward": {
      "type": "array",
      "description": "Items handed off to future work — risks, debt, unresolved gaps accepted at closure.",
      "items": {
        "type": "string"
      }
    }
  }
}
