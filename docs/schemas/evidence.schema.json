{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence.schema.json",
  "title": "GEAS Agent Evidence",
  "description": "Dispatch schema for task-level evidence_kind-specific evidence files.",
  "$defs": {
    "evidenceKind": {
      "type": "string",
      "enum": [
        "implementation",
        "review",
        "verification",
        "challenge",
        "decision"
      ],
      "description": "Dispatch key selecting the concrete task evidence schema."
    }
  },
  "type": "object",
  "required": [
    "evidence_kind"
  ],
  "properties": {
    "evidence_kind": {
      "$ref": "#/$defs/evidenceKind"
    }
  },
  "oneOf": [
    { "$ref": "evidence-implementation.schema.json" },
    { "$ref": "evidence-review.schema.json" },
    { "$ref": "evidence-verification.schema.json" },
    { "$ref": "evidence-challenge.schema.json" },
    { "$ref": "evidence-decision.schema.json" }
  ]
}
