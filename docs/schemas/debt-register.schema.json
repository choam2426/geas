{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DebtRegister",
  "description": "Mission-level debt register. Captures outstanding burdens that this mission intentionally carries forward.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "items"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "debt_id",
          "severity",
          "kind",
          "title",
          "description",
          "status"
        ],
        "properties": {
          "debt_id": {
            "type": "string",
            "description": "Stable identifier for this debt item."
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "normal",
              "high",
              "critical"
            ]
          },
          "kind": {
            "type": "string",
            "enum": [
              "output_quality",
              "verification_gap",
              "structural",
              "risk",
              "process",
              "documentation",
              "operations"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "introduced_by_task_id": {
            "type": "string",
            "description": "Task in which this debt was first observed."
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "resolved",
              "dropped"
            ]
          },
          "target_phase": {
            "type": "string",
            "enum": [
              "polishing",
              "consolidating",
              "future"
            ],
            "description": "Earliest phase in which this debt is expected to be revisited."
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
