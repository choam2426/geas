{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Geas Debts",
  "description": "Mission-level list of outstanding burdens this mission intentionally carries forward. May also include open debt items carried over from prior missions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "entries",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "mission_id": {
      "type": "string",
      "pattern": "^mission-[0-9]{8}-[a-zA-Z0-9]{8}$"
    },
    "entries": {
      "type": "array",
      "description": "Registered debt entries. Empty array if this mission registered no debts.",
      "items": {
        "$ref": "#/$defs/debtItem"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "debtItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "debt_id",
        "severity",
        "kind",
        "title",
        "description",
        "status",
        "introduced_by",
        "resolved_by",
        "resolution_rationale"
      ],
      "properties": {
        "debt_id": {
          "type": "string",
          "pattern": "^debt-[0-9]{3}$",
          "description": "Stable identifier for this debt entry."
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "normal",
            "high",
            "critical"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "output_quality",
            "verification_gap",
            "structural",
            "risk",
            "process",
            "documentation",
            "operations"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "introduced_by": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mission_id",
            "task_id"
          ],
          "properties": {
            "mission_id": {
              "type": "string",
              "pattern": "^mission-[0-9]{8}-[a-zA-Z0-9]{8}$"
            },
            "task_id": {
              "type": "string",
              "pattern": "^task-[0-9]{3}$"
            }
          },
          "description": "Mission and task where this debt was first observed. For carry-forward debts from prior missions, points to the originating mission/task."
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "resolved",
            "dropped"
          ]
        },
        "resolved_by": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "mission_id",
                "task_id"
              ],
              "properties": {
                "mission_id": {
                  "type": "string",
                  "pattern": "^mission-[0-9]{8}-[a-zA-Z0-9]{8}$"
                },
                "task_id": {
                  "type": "string",
                  "pattern": "^task-[0-9]{3}$"
                }
              }
            }
          ],
          "description": "Mission and task where this debt was resolved or dropped. Null while status is open."
        },
        "resolution_rationale": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ],
          "description": "Reasoning for the status change to resolved or dropped, including the evidence or context that justifies it. Null while status is open."
        }
      }
    }
  }
}
