{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GapAssessment",
  "description": "Mission-level assessment of the difference between committed scope and actual delivery. Narrative scope summaries describe the scope as actually reflected in delivery, which may drift from the original mission spec.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scope_in_summary",
    "scope_out_summary",
    "fully_delivered",
    "partially_delivered",
    "not_delivered",
    "intentional_cuts",
    "unexpected_additions"
  ],
  "properties": {
    "scope_in_summary": {
      "type": "string",
      "minLength": 1,
      "description": "Summary of in-scope work as actually reflected in delivery."
    },
    "scope_out_summary": {
      "type": "string",
      "minLength": 1,
      "description": "Summary of out-of-scope work as actually reflected in delivery."
    },
    "fully_delivered": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "partially_delivered": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "not_delivered": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "intentional_cuts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unexpected_additions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
