{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MissionSpec",
  "type": "object",
  "required": [
    "mission_id",
    "mode",
    "mission",
    "done_when",
    "target_user",
    "user_approved",
    "scope",
    "acceptance_criteria",
    "constraints",
    "affected_surfaces",
    "risk_notes",
    "assumptions",
    "ambiguities"
  ],
  "properties": {
    "mission_id": {
      "type": "string",
      "pattern": "^mission-([0-9]{3}|[0-9]{8}-[a-zA-Z0-9]{8})$"
    },
    "domain_profile": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "lightweight",
        "standard",
        "full_depth"
      ]
    },
    "mission": {
      "type": "string",
      "minLength": 1
    },
    "done_when": {
      "type": "string",
      "minLength": 1
    },
    "target_user": {
      "type": "string",
      "minLength": 1
    },
    "user_approved": {
      "type": "boolean"
    },
    "scope": {
      "type": "object",
      "required": [
        "in",
        "out"
      ],
      "properties": {
        "in": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "out": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "affected_surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ambiguities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
