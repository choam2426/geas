{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence-closure.schema.json",
  "title": "GEAS Task Closure Evidence",
  "type": "object",
  "properties": {
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_kind": {
      "const": "closure"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approved",
        "changes_requested",
        "escalated",
        "cancelled"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "memory_suggestions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "debt_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "output_quality",
              "verification_gap",
              "structural",
              "risk",
              "process",
              "documentation",
              "operations"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "normal",
              "low"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "title",
          "kind",
          "severity",
          "summary"
        ],
        "additionalProperties": true
      }
    },
    "gap_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "under_delivery",
              "over_delivery",
              "risk_transfer",
              "learning_gain"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "kind",
          "summary"
        ],
        "additionalProperties": true
      }
    },
    "rewind_target": {
      "type": "string",
      "enum": [
        "ready",
        "implementing",
        "reviewed"
      ],
      "description": "State to revert to when verdict is changes_requested. Not applicable for other verdicts."
    },
    "superseded_by": {
      "type": "string",
      "description": "Reference to a replacement task contract when verdict is cancelled because a new contract supersedes this one."
    },
    "revision_ref": {
      "type": "string"
    }
  },
  "required": [
    "agent",
    "task_id",
    "evidence_kind",
    "summary",
    "verdict",
    "rationale"
  ],
  "additionalProperties": true
}
