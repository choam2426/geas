function nextNumber(dir, prefix) {
  if (!(0, import_node_fs.existsSync)(dir)) return 1;
  let max = 0;
  const re = new RegExp(`^${prefix.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}-(\\d{3})\\.yaml$`);
  for (const file of (0, import_node_fs.readdirSync)(dir)) {
    const m = file.match(re);
    if (m) {
      const n = parseInt(m[1], 10);
      if (n > max) max = n;
    }
  }
  return max + 1;
}
function pad3(n) {
  return String(n).padStart(3, "0");
}
function readLatestNumbered(dir, prefix) {
  if (!(0, import_node_fs.existsSync)(dir)) return null;
  const re = new RegExp(`^${prefix.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}-(\\d{3})\\.yaml$`);
  let best = null;
  for (const file of (0, import_node_fs.readdirSync)(dir)) {
    const m = file.match(re);
    if (m) {
      const n = parseInt(m[1], 10);
      if (!best || n > best.number) best = { number: n, file };
    }
  }
  if (!best) return null;
  const p = (0, import_node_path.join)(dir, best.file);
  return { number: best.number, payload: readYaml(p), path: p };
}
function writeNumberedArtifact(dir, prefix, payload) {
  ensureDir(dir);
  const n = nextNumber(dir, prefix);
  const path = (0, import_node_path.join)(dir, `${prefix}-${pad3(n)}.yaml`);
  writeYamlAtomic(path, payload);
  return { path, number: n };
}
function generateMissionId(now = /* @__PURE__ */ new Date()) {
  const yyyy = now.getUTCFullYear().toString();
  const mm = String(now.getUTCMonth() + 1).padStart(2, "0");
  const dd = String(now.getUTCDate()).padStart(2, "0");
  const random = (0, import_node_crypto.randomBytes)(8).toString("hex").slice(0, 6);
  return `${yyyy}${mm}${dd}-${random}`;
}

